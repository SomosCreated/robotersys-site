---
/**
 * ServiceCard — spotlight card for the services grid.
 *
 * Layout: FIG. tag (top-left) + Solar icon (top-right) + uppercase title + mono description.
 * Body text uses text-zinc-400 (≥4.5:1 on #050505 background) at text-sm (14px) for WCAG AA.
 * Spotlight border glow is driven by spotlight.ts which sets --mouse-x/--mouse-y on each card.
 */
import { Icon } from 'astro-icon/components';

interface Props {
  fig: string;
  icon: string;
  title: string;
  desc: string;
}

const { fig, icon, title, desc } = Astro.props;
---

<div
  class="group relative border-line border-r border-b min-h-[280px] flex flex-col spotlight-card"
  style="--mouse-x:0px;--mouse-y:0px;"
>
  <!-- Inner sheen (driven by spotlight.ts) -->
  <div
    class="inner-sheen absolute inset-0 pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="p-8 h-full flex flex-col relative z-10">
    <!-- Header row: FIG. tag + icon -->
    <div class="flex justify-between items-start mb-6">
      <span
        class="text-[10px] font-mono text-muted border border-line px-2 py-1 group-hover:border-accent/50 group-hover:text-accent transition-all bg-bg"
      >
        {fig}
      </span>
      <Icon
        name={icon}
        class="text-fg group-hover:text-strong transition-colors"
        width={24}
        height={24}
        aria-hidden="true"
      />
    </div>

    <!-- Title -->
    <h3
      class="text-[1rem] font-medium text-strong uppercase tracking-tight mb-3 group-hover:text-accent transition-colors"
    >
      {title}
    </h3>

    <!-- Description — zinc-400 at 14px ensures WCAG AA contrast -->
    <p class="text-sm text-muted leading-relaxed">
      {desc}
    </p>
  </div>
</div>
