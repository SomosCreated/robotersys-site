---
import { Icon } from 'astro-icon/components';
import type { Locale } from '@/i18n/types';
import { t } from '@/i18n';
import { localizedPath } from '@/i18n/routes';

interface Props { locale?: Locale; }
const { locale = 'pt' } = Astro.props;

type FooterNavItem = { key: string; href: string };
const navItems: FooterNavItem[] = [
  { key: 'nav.services', href: localizedPath('servicos', locale) },
  { key: 'nav.parts',    href: localizedPath('pecas', locale) },
  { key: 'nav.systems',  href: localizedPath('sistemas', locale) },
  { key: 'nav.pushcorp', href: localizedPath('pushcorp', locale) },
  { key: 'nav.about',    href: localizedPath('sobre', locale) },
  { key: 'nav.careers',  href: localizedPath('carreiras', locale) },
  // {/* Phase 4 */} — blog special-cased until blog pages exist per locale
  { key: 'nav.blog',     href: locale === 'pt' ? '/blog/' : `/${locale}/blog/` },
];

// Social brand icons. LinkedIn URL varies by locale (EN → USA page, others → BR page).
const linkedinHref = locale === 'en'
  ? 'https://www.linkedin.com/company/robotersys-usa/'
  : 'https://www.linkedin.com/company/robotersys./';

const socialLinks = [
  { label: 'LinkedIn', href: linkedinHref, icon: 'simple-icons:linkedin' },
  { label: 'Instagram', href: 'https://www.instagram.com/robotersys', icon: 'simple-icons:instagram' },
  { label: 'Facebook', href: 'https://www.facebook.com/robotersys', icon: 'simple-icons:facebook' },
] as const;
---

<footer class="border-t border-line bg-bg relative z-20" aria-label="Rodapé">

  <!-- main footer grid -->
  <div class="px-8 py-12 grid grid-cols-1 md:grid-cols-3 gap-12 border-b border-line">

    <!-- brand + contact -->
    <div class="space-y-6">
      <a class="flex items-center group" href={localizedPath('home', locale)}>
        <span class="text-3xl font-medium text-strong tracking-tight">
          RoboterSys<span class="text-accent">.</span>
        </span>
      </a>
      <p class="text-[11px] text-muted leading-relaxed max-w-xs">
        Especialista independente em manutenção, reparos e peças para robôs KUKA.
      </p>

      <!-- contact details -->
      <address class="not-italic space-y-4 text-[10px] text-muted">
        <!-- Brazil HQ -->
        <div class="space-y-2">
          <div class="text-[9px] font-mono uppercase tracking-widest text-fg">BR · Brasil</div>
          <div class="flex items-start gap-2">
            <Icon name="solar:map-point-linear" width={12} class="mt-0.5 shrink-0 text-muted" aria-hidden="true" />
            <span>R. Parati, 335C — Joinville/SC</span>
          </div>
          <div class="flex items-center gap-2">
            <Icon name="solar:letter-linear" width={12} class="shrink-0 text-muted" aria-hidden="true" />
            <a
              class="hover:text-strong transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
              href="mailto:contato.site@robotersys.com.br"
            >
              contato.site@robotersys.com.br
            </a>
          </div>
          <div class="flex items-center gap-2">
            <Icon name="solar:phone-linear" width={12} class="shrink-0 text-muted" aria-hidden="true" />
            <a
              class="hover:text-strong transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
              href="tel:+554741010987"
            >
              (47) 4101 0987
            </a>
          </div>
        </div>

        <!-- USA office -->
        <div class="space-y-2 pt-3 border-t border-line/50">
          <div class="text-[9px] font-mono uppercase tracking-widest text-fg">US · USA</div>
          <div class="flex items-start gap-2">
            <Icon name="solar:map-point-linear" width={12} class="mt-0.5 shrink-0 text-muted" aria-hidden="true" />
            <span>1711 Amazing Way, Suite 213 B<br />Ocoee, FL 34761 — US</span>
          </div>
          <div class="flex items-center gap-2">
            <Icon name="solar:phone-linear" width={12} class="shrink-0 text-muted" aria-hidden="true" />
            <a
              class="hover:text-strong transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
              href="tel:+14078248933"
            >
              +1 407 824 8933
            </a>
          </div>
          <div class="flex items-center gap-2">
            <Icon name="solar:phone-linear" width={12} class="shrink-0 text-muted" aria-hidden="true" />
            <a
              class="hover:text-strong transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
              href="tel:+17862927410"
            >
              +1 786 292 7410
            </a>
          </div>
        </div>
      </address>
    </div>

    <!-- nav links -->
    <div class="space-y-4">
      <div class="text-[9px] font-mono text-muted uppercase tracking-widest mb-4">// Navegação</div>
      <nav aria-label="Links de rodapé">
        <ul class="grid grid-cols-2 gap-2">
          {navItems.map(({ key, href }) => (
            <li>
              <a
                class="text-[10px] text-muted hover:text-strong transition-colors uppercase tracking-widest flex items-center gap-2 group focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
                href={href}
              >
                <span class="w-1 h-px bg-line group-hover:w-3 group-hover:bg-accent transition-all" aria-hidden="true"></span>
                {t(locale, key)}
              </a>
            </li>
          ))}
          <li>
            <a
              class="text-[10px] text-accent hover:text-orange-500 transition-colors uppercase tracking-widest flex items-center gap-2 group focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
              href="/contato/"
            >
              <span class="w-1 h-px bg-accent group-hover:w-3 transition-all" aria-hidden="true"></span>
              {t(locale, 'nav.contact')}
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <!-- social + certifications -->
    <div class="space-y-6">
      <div>
        <div class="text-[9px] font-mono text-muted uppercase tracking-widest mb-4">// Redes Sociais</div>
        <div class="flex items-center gap-3">
          {socialLinks.map(({ label, href, icon }) => (
            <a
              class="w-8 h-8 border border-line flex items-center justify-center text-muted hover:text-strong hover:border-muted transition-all focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
              href={href}
              aria-label={label}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Icon name={icon} width={16} aria-hidden="true" />
            </a>
          ))}
        </div>
      </div>

      <!-- GPTW seal — shown only in PT (Brazil certification) -->
      {locale === 'pt' && (
        <div>
          <img
            src="/robotersys/img/GPTW-Selos.webp"
            alt="Selos de certificação"
            width={160}
            height={80}
            style="max-height: 80px; width: auto;"
            loading="lazy"
            decoding="async"
          />
        </div>
      )}

      <!-- D-U-N-S seal — shown only in EN (US trust signal) -->
      {locale === 'en' && (
        <div>
          <img
            src="/robotersys/img/duns-selo.webp"
            alt="D-U-N-S Registered — RoboterSys"
            class="h-16 md:h-20 w-auto"
            loading="lazy"
            decoding="async"
          />
        </div>
      )}

      <!-- CTA contato -->
      <a
        class="block w-full text-center py-3 bg-accent text-white text-[10px] font-mono uppercase tracking-widest hover:bg-orange-500 transition-all flex items-center justify-center gap-2 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400"
        href={localizedPath('contato', locale)}
      >
        {t(locale, 'header.cta')}
        <Icon name="solar:arrow-right-linear" class="group-hover:translate-x-1 transition-transform" width={12} aria-hidden="true" />
      </a>
    </div>
  </div>

  <!-- KUKA independence disclaimer — full-width paragraph below the nav menu -->
  <div class="px-8 py-6 border-b border-line">
    <p class="text-[11px] text-muted leading-relaxed normal-case text-center whitespace-pre-line">
      {t(locale, 'legal.footer_kuka_disclaimer')}
    </p>
  </div>

  <!-- bottom bar -->
  <div class="bg-surface px-8 py-4 flex flex-col md:flex-row items-center justify-between gap-3 text-[10px] uppercase tracking-wider text-muted">
    <span>© 2026 RoboterSys Serviços do Brasil Ltda</span>
    <!-- D-U-N-S number — all locales -->
    <span class="normal-case">{t(locale, 'legal.duns')}</span>
    <!-- CNPJ — all locales -->
    <span class="normal-case">CNPJ: 34.412.533/0001-00</span>
    <!-- Legal links -->
    <nav aria-label="Links legais" class="flex items-center gap-3">
      <a
        href={localizedPath('privacidade', locale)}
        class="hover:text-strong transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent normal-case"
      >
        {t(locale, 'legal.footer_privacy')}
      </a>
      <span class="text-line" aria-hidden="true">·</span>
      <a
        href={localizedPath('cookies', locale)}
        class="hover:text-strong transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent normal-case"
      >
        {t(locale, 'legal.footer_cookies')}
      </a>
      <span class="text-line" aria-hidden="true">·</span>
      <!-- Reopens the consent banner (LGPD/GDPR — right to change choice) -->
      <button
        type="button"
        data-cookie-settings
        class="hover:text-strong transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent normal-case"
      >
        {t(locale, 'consent.settings')}
      </button>
    </nav>
  </div>

  <!-- "Desenvolvido por CREATED" — full-width row at the very bottom -->
  <div class="bg-surface border-t border-line px-8 py-3 flex items-center justify-center text-[10px] uppercase tracking-wider text-muted">
    <span class="normal-case">
      Desenvolvido por{' '}
      <a
        href="https://created.com.br/?utm_source=robotersys&utm_medium=footer&utm_campaign=developed_by"
        target="_blank"
        rel="noopener"
        class="hover:text-accent transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
      >
        <strong>CREATED</strong>
      </a>
    </span>
  </div>
</footer>
