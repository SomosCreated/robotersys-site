---
import { Icon } from 'astro-icon/components';
import type { Locale } from '@/i18n/types';
import { t } from '@/i18n';

interface Props { locale?: Locale; }
const { locale = 'pt' } = Astro.props;

const navItems = [
  { key: 'nav.services',  href: '/servicos/' },
  { key: 'nav.parts',     href: '/pecas-de-reposicao/' },
  { key: 'nav.systems',   href: '/sistemas-roboticos/' },
  { key: 'nav.about',     href: '/sobre-nos/' },
  { key: 'nav.careers',   href: '/trabalhe-conosco/' },
  { key: 'nav.blog',      href: '/blog/' },
] as const;

// Social brand icons via the simple-icons set. NOTE: handles are placeholders — confirm real URLs with client.
const socialLinks = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/company/robotersys', icon: 'simple-icons:linkedin' },
  { label: 'Instagram', href: 'https://www.instagram.com/robotersys', icon: 'simple-icons:instagram' },
  { label: 'Facebook', href: 'https://www.facebook.com/robotersys', icon: 'simple-icons:facebook' },
] as const;
---

<footer class="border-t border-zinc-800 bg-[#050505] font-mono relative z-20" aria-label="Rodapé">

  <!-- main footer grid -->
  <div class="px-8 py-12 grid grid-cols-1 md:grid-cols-3 gap-12 border-b border-zinc-800">

    <!-- brand + contact -->
    <div class="space-y-6">
      <a class="flex items-center gap-2 group" href="/">
        <Icon
          name="solar:streets-navigation-linear"
          class="text-white group-hover:text-orange-600 transition-colors"
          width={20}
          aria-hidden="true"
        />
        <span class="text-sm font-medium text-white tracking-widest uppercase">
          ROBOTER<span class="text-zinc-600">SYS</span>
        </span>
      </a>
      <p class="text-[11px] text-zinc-400 leading-relaxed max-w-xs">
        Especialista independente em manutenção, reparos e peças para robôs KUKA.
      </p>

      <!-- contact details -->
      <address class="not-italic space-y-2 text-[10px] text-zinc-400">
        <div class="flex items-start gap-2">
          <Icon name="solar:map-point-linear" width={12} class="mt-0.5 shrink-0 text-zinc-600" aria-hidden="true" />
          <span>R. Parati, 335C — Joinville/SC</span>
        </div>
        <div class="flex items-center gap-2">
          <Icon name="solar:letter-linear" width={12} class="shrink-0 text-zinc-600" aria-hidden="true" />
          <a
            class="hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-orange-600"
            href="mailto:contato.site@robotersys.com.br"
          >
            contato.site@robotersys.com.br
          </a>
        </div>
        <div class="flex items-center gap-2">
          <Icon name="solar:phone-linear" width={12} class="shrink-0 text-zinc-600" aria-hidden="true" />
          <a
            class="hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-orange-600"
            href="tel:+554741010987"
          >
            (47) 4101 0987
          </a>
        </div>
      </address>
    </div>

    <!-- nav links -->
    <div class="space-y-4">
      <div class="text-[9px] font-mono text-zinc-500 uppercase tracking-widest mb-4">// Navegação</div>
      <nav aria-label="Links de rodapé">
        <ul class="space-y-2">
          {navItems.map(({ key, href }) => (
            <li>
              <a
                class="text-[10px] text-zinc-400 hover:text-white transition-colors uppercase tracking-widest flex items-center gap-2 group focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-orange-600"
                href={href}
              >
                <span class="w-1 h-px bg-zinc-700 group-hover:w-3 group-hover:bg-orange-600 transition-all" aria-hidden="true"></span>
                {t(locale, key)}
              </a>
            </li>
          ))}
          <li>
            <a
              class="text-[10px] text-orange-600 hover:text-orange-500 transition-colors uppercase tracking-widest flex items-center gap-2 group focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-orange-600"
              href="/contato/"
            >
              <span class="w-1 h-px bg-orange-600 group-hover:w-3 transition-all" aria-hidden="true"></span>
              {t(locale, 'nav.contact')}
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <!-- social + certifications -->
    <div class="space-y-6">
      <div>
        <div class="text-[9px] font-mono text-zinc-500 uppercase tracking-widest mb-4">// Redes Sociais</div>
        <div class="flex items-center gap-3">
          {socialLinks.map(({ label, href, icon }) => (
            <a
              class="w-8 h-8 border border-zinc-800 flex items-center justify-center text-zinc-400 hover:text-white hover:border-zinc-600 transition-all focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-orange-600"
              href={href}
              aria-label={label}
              target="_blank"
              rel="noopener noreferrer"
            >
              <Icon name={icon} width={16} aria-hidden="true" />
            </a>
          ))}
        </div>
      </div>

      <!-- GPTW seal -->
      <div class="border border-zinc-800 bg-zinc-900/20 p-3 inline-flex flex-col gap-1">
        <div class="text-[8px] font-mono text-zinc-600 uppercase tracking-widest">Certificação</div>
        <div class="text-[10px] font-mono text-green-500 uppercase tracking-widest flex items-center gap-2">
          <Icon name="solar:shield-check-linear" width={12} aria-hidden="true" />
          GPTW — Great Place to Work
        </div>
      </div>

      <!-- CTA contato -->
      <a
        class="block w-full text-center py-3 bg-orange-600 text-white text-[10px] font-mono uppercase tracking-widest hover:bg-orange-500 transition-all flex items-center justify-center gap-2 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400"
        href="/contato/"
      >
        {t(locale, 'header.cta')}
        <Icon name="solar:arrow-right-linear" class="group-hover:translate-x-1 transition-transform" width={12} aria-hidden="true" />
      </a>
    </div>
  </div>

  <!-- bottom bar -->
  <div class="bg-[#080808] px-8 py-4 flex flex-col md:flex-row items-center justify-between gap-3 text-[10px] uppercase tracking-wider text-zinc-400">
    <div class="flex flex-col md:flex-row items-center gap-4 text-center md:text-left">
      <span>© 2026 RoboterSys Serviços do Brasil Ltda</span>
    </div>
    <div class="text-center text-[10px] text-zinc-500 max-w-md leading-relaxed">
      Independente da KUKA Roboter do Brasil; a marca KUKA pertence à KUKA Roboter do Brasil.
    </div>
  </div>
</footer>
