---
/**
 * FAQ — accessible accordion (native <details>) + FAQPage JSON-LD.
 *
 * Content + localized labels come from src/i18n/faq.ts (type-safe per locale).
 * The visible Q&A and the structured data are built from the SAME source, so they
 * never drift — Google requires FAQ schema to match the on-page content.
 */
import SectionLabel from '@/components/SectionLabel.astro';
import { Icon } from 'astro-icon/components';
import { FAQ, FAQ_LABELS, type FaqKey } from '@/i18n/faq';
import type { Locale } from '@/i18n/types';

interface Props {
  locale: Locale;
  faqKey: FaqKey;
}
const { locale, faqKey } = Astro.props;

const items = FAQ[locale][faqKey];
const { label, heading } = FAQ_LABELS[locale];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---

<section class="py-16 border-b border-line bg-bg" aria-labelledby="faq-heading">
  <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
    <SectionLabel text={label} />
    <h2
      id="faq-heading"
      class="text-2xl md:text-3xl font-medium text-strong uppercase tracking-tight leading-tight mb-10 sys-reveal sys-rise"
    >
      {heading}
    </h2>

    <div class="border-y border-line divide-y divide-line sys-reveal">
      {items.map(({ q, a }) => (
        <details class="faq-item group">
          <summary
            class="flex items-center justify-between gap-4 cursor-pointer list-none py-5 text-base md:text-lg font-medium text-strong hover:text-accent transition-colors focus-visible:outline-none focus-visible:text-accent"
          >
            <span>{q}</span>
            <Icon
              name="solar:alt-arrow-down-linear"
              width={20}
              class="shrink-0 text-accent transition-transform duration-200 group-open:rotate-180"
              aria-hidden="true"
            />
          </summary>
          <p class="text-muted text-sm leading-relaxed pb-5 -mt-1 max-w-3xl">{a}</p>
        </details>
      ))}
    </div>
  </div>

  <!-- FAQPage structured data (matches the visible Q&A above) -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</section>

<style>
  /* Hide the native disclosure marker — we render our own chevron icon. */
  .faq-item > summary::-webkit-details-marker { display: none; }
  .faq-item > summary::marker { content: ''; }
</style>
