---
/**
 * FeatureCard — generic bordered HUD card.
 *
 * Layout: Solar icon + title + description.
 * Used for: diferenciais, aplicações, valores, lifecycle steps.
 *
 * WCAG AA: title white, desc zinc-400 (≥4.5:1 on #050505).
 * prefers-reduced-motion: no transitions added (border hover is CSS).
 */
import { Icon } from 'astro-icon/components';

interface Props {
  /** Icon name from @iconify-json/solar (e.g. 'solar:delivery-linear') */
  icon: string;
  /** Card title — displayed in white uppercase */
  title: string;
  /** Card description — displayed in zinc-400 mono */
  desc: string;
  /** Optional fig/number label (e.g. 'FIG. 01') */
  fig?: string;
  /** Optional accent border on the left */
  accent?: boolean;
}

const { icon, title, desc, fig, accent = false } = Astro.props;
---

<article
  class:list={[
    'flex flex-col gap-4 border border-zinc-800 p-6 bg-ink/30 hover:border-zinc-700 transition-colors',
    accent ? 'border-l-2 border-l-accent' : '',
  ]}
>
  <!-- Header row: icon + optional fig -->
  <div class="flex items-start justify-between gap-4">
    <!-- Icon container -->
    <div
      class="h-10 w-10 flex-shrink-0 border border-zinc-800 bg-zinc-900/50 flex items-center justify-center"
      aria-hidden="true"
    >
      <Icon name={icon} class="text-accent" width={20} height={20} aria-hidden="true" />
    </div>

    {fig && (
      <span class="text-[9px] font-mono text-zinc-500 uppercase tracking-widest border border-zinc-800 px-2 py-1 bg-ink">
        {fig}
      </span>
    )}
  </div>

  <!-- Title -->
  <h3 class="text-sm font-medium text-white uppercase tracking-tight leading-snug">
    {title}
  </h3>

  <!-- Description -->
  <p class="text-sm text-zinc-400 font-mono leading-relaxed">
    {desc}
  </p>
</article>
