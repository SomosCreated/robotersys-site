---
/**
 * Emergency24hCTA — 24h emergency support call-to-action block.
 *
 * Layout: section background is the same factory/robot photo as the hero,
 * with a theme-aware scrim for readability. Inside, a HUD card splits into
 * two columns: the WhatsApp support-group QR code (PT only, and desktop only —
 * a phone user can't scan their own screen) and the texts (headline + subtext +
 * WhatsApp button). The QR is hidden on mobile and for non-PT locales; the texts
 * then span the full width.
 *
 * WhatsApp button + QR link to the RoboterSys 24h support WhatsApp GROUP
 * (chat.whatsapp.com invite).
 *
 * Accessibility: role="region" + aria-label, motion behind prefers-reduced-motion.
 */
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { t } from '@/i18n';
import type { Locale } from '@/i18n/types';
import emergencyBgImg from '@/assets/robotersys/hero-robot.webp';

interface Props {
  locale?: Locale;
}
const { locale = 'pt' } = Astro.props;

// The WhatsApp support-group QR is a Brazil-only asset → PT only.
// It is also hidden on mobile (see `hidden md:flex` below): a phone user
// cannot scan a QR shown on their own screen.
const showQr = locale === 'pt';
---

<section
  class="relative border-t border-b border-line py-20 px-6 md:px-12 overflow-hidden sys-reveal"
  aria-label={t(locale, 'emergency.section_label')}
  role="region"
>
  <!-- ── Background: same hero photo + theme-aware scrim for readability ── -->
  <Image
    src={emergencyBgImg}
    alt=""
    aria-hidden="true"
    width={1600}
    height={900}
    class="absolute inset-0 w-full h-full object-cover pointer-events-none select-none"
    loading="lazy"
    decoding="async"
  />
  <!-- No colour layer over the photo (per brand request) — the content card below
       provides its own background for text contrast. -->

  <div class="max-w-6xl mx-auto relative">

    <!-- HUD card -->
    <div class="relative border border-line bg-surface/90 backdrop-blur-sm p-8 md:p-12 overflow-hidden">

      <!-- Left accent bar -->
      <div class="absolute left-0 top-8 bottom-8 w-0.5 bg-accent" aria-hidden="true"></div>

      <!-- Top-right corner: pulsing green "online" indicator -->
      <div
        class="absolute top-6 right-6 flex items-center gap-2"
        aria-label={t(locale, 'emergency.online_label')}
      >
        <span class="relative flex h-2.5 w-2.5" aria-hidden="true">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-ok opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-ok"></span>
        </span>
        <span class="text-[9px] font-mono text-ok uppercase tracking-widest hidden sm:inline">
          {t(locale, 'emergency.online_label')}
        </span>
      </div>

      <!-- Two columns: QR (PT only) | texts -->
      <div
        class:list={[
          'grid gap-8 md:gap-12 items-center',
          showQr ? 'md:grid-cols-[auto_1fr]' : 'grid-cols-1',
        ]}
      >

        {showQr && (
          <!-- ── Column 1: WhatsApp support-group QR ── -->
          <!--
            PLACEHOLDER: Replace 55XXXXXXXXXXX with the actual WhatsApp number
            (country code 55 + DDD + number, no spaces or dashes) before going live.
          -->
          <div class="hidden md:flex flex-col items-center gap-3 order-1">
            <a
              href="https://chat.whatsapp.com/FyPvBjF3HAPF4aPrToRnxh"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Aponte a câmera para entrar no grupo de suporte 24h no WhatsApp — abre em nova aba"
              class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-sm"
            >
              <img
                src="/robotersys/img/whatsapp-qr.png"
                alt="QR Code — Suporte 24h RoboterSys no WhatsApp"
                width="200"
                height="200"
                loading="lazy"
                decoding="async"
                class="w-44 h-44 md:w-52 md:h-52 bg-white p-2 rounded-sm border border-line hover:opacity-90 transition-opacity"
              />
            </a>
            <p class="text-[10px] font-mono text-muted uppercase tracking-widest text-center leading-tight">
              {t(locale, 'emergency.qr_caption')}
            </p>
          </div>
        )}

        <!-- ── Column 2: texts ── -->
        <div class="order-2 min-w-0">
          <!-- Section label -->
          <div class="text-[10px] font-mono text-accent uppercase tracking-widest flex items-center gap-2 mb-6">
            <span class="w-1.5 h-1.5 bg-accent animate-pulse" aria-hidden="true"></span>
            // {t(locale, 'emergency.section_label')}
          </div>

          <!-- Headline -->
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-medium text-strong uppercase tracking-tight leading-tight mb-4 sys-reveal sys-rise">
            {t(locale, 'emergency.headline_1')}<br />
            <span class="text-accent">{t(locale, 'emergency.headline_accent')}</span>
          </h2>

          <!-- Sub-text -->
          <p class="text-[1rem] text-muted leading-relaxed mb-8 max-w-lg border-l-2 border-line pl-4">
            {t(locale, 'emergency.subtext')}
          </p>

          <!-- WhatsApp CTA button -->
          <a
            href="https://chat.whatsapp.com/FyPvBjF3HAPF4aPrToRnxh"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 bg-green-600 hover:bg-green-500 text-white text-xs font-mono uppercase tracking-widest px-8 py-4 transition-all shadow-[0_0_20px_rgba(34,197,94,0.25)] hover:shadow-[0_0_40px_rgba(34,197,94,0.5)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
            aria-label={`${t(locale, 'emergency.button')} — ${t(locale, 'emergency.section_label')}`}
          >
            <Icon
              name="solar:phone-calling-rounded-linear"
              class="group-hover:scale-110 transition-transform"
              width={18}
              height={18}
              aria-hidden="true"
            />
            {t(locale, 'emergency.button')}
            <Icon
              name="solar:arrow-right-linear"
              class="group-hover:translate-x-1 transition-transform"
              width={16}
              height={16}
              aria-hidden="true"
            />
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
