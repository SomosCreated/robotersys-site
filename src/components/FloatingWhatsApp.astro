---
/**
 * FloatingWhatsApp — fixed circle CTA that cycles through 4 states every ~2.5 s:
 *
 *   State 1: WhatsApp icon    — green background (bg-ok / green-600),  white icon
 *   State 2: Siren icon       — orange background (bg-accent),          white icon
 *   State 3: t('whatsapp.idle')   text — orange background,            white text
 *   State 4: t('whatsapp.invite') text — orange background,            white text
 *
 * Same size/shape (w-16 h-16 rounded-full) across all states.
 * prefers-reduced-motion: static State 1 (WhatsApp icon, green), no cycling.
 *
 * PLACEHOLDER: Replace 55XXXXXXXXXXX with the real WhatsApp number
 * (country code 55 + DDD + number, no spaces or dashes) before going live.
 */
import { Icon } from 'astro-icon/components';
import { t } from '@/i18n';
import type { Locale } from '@/i18n/types';

interface Props {
  locale?: Locale;
}
const { locale = 'pt' } = Astro.props;
---

<!-- Links to the RoboterSys 24h support WhatsApp GROUP (chat.whatsapp.com invite). -->
<a
  id="floating-whatsapp"
  href="https://chat.whatsapp.com/FyPvBjF3HAPF4aPrToRnxh"
  target="_blank"
  rel="noopener noreferrer"
  aria-label={t(locale, 'whatsapp.aria')}
  class="
    fixed bottom-6 right-6 z-50
    w-16 h-16 rounded-full
    flex items-center justify-center
    shadow-[0_8px_24px_rgba(0,0,0,0.5)]
    ring-1 ring-black/10
    transition-all duration-300
    focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-accent
  "
>
  <!-- State 1: WhatsApp icon — green bg -->
  <span
    id="fwa-state-1"
    class="fwa-state fwa-active absolute inset-0 rounded-full flex items-center justify-center bg-green-600"
    aria-hidden="true"
  >
    <Icon
      name="simple-icons:whatsapp"
      width={28}
      height={28}
      class="text-white flex-shrink-0"
      aria-hidden="true"
    />
  </span>

  <!-- State 2: Siren icon — orange bg -->
  <span
    id="fwa-state-2"
    class="fwa-state absolute inset-0 rounded-full flex items-center justify-center bg-accent"
    aria-hidden="true"
  >
    <Icon
      name="solar:siren-rounded-bold"
      width={28}
      height={28}
      class="text-white flex-shrink-0 fwa-pulse-icon"
      aria-hidden="true"
    />
  </span>

  <!-- State 3: idle text — orange bg -->
  <span
    id="fwa-state-3"
    class="fwa-state absolute inset-0 rounded-full flex items-center justify-center bg-accent px-2"
    aria-hidden="true"
  >
    <span class="text-white text-[10px] font-mono font-semibold uppercase tracking-wide leading-tight text-center">
      {t(locale, 'whatsapp.idle')}
    </span>
  </span>

  <!-- State 4: invite text — orange bg -->
  <span
    id="fwa-state-4"
    class="fwa-state absolute inset-0 rounded-full flex items-center justify-center bg-accent px-2"
    aria-hidden="true"
  >
    <span class="text-white text-[10px] font-mono font-semibold uppercase tracking-wide leading-tight text-center">
      {t(locale, 'whatsapp.invite')}
    </span>
  </span>
</a>

<style>
  /* Visibility is controlled entirely by the .fwa-active class (toggled by JS).
     State 1 carries .fwa-active in the markup so it shows before/without JS.
     These class rules (specificity 0,2,0) intentionally out-rank Tailwind's
     .flex utility (0,1,0). NOTE: the previous #id defaults (specificity 1,0,0)
     out-ranked this toggle and froze the button on State 1 — that was the
     "WhatsApp button doesn't cycle" bug. Keep these selectors class-based. */
  :global(.fwa-state.fwa-active)       { display: flex; }
  :global(.fwa-state:not(.fwa-active)) { display: none; }

  /* Siren pulse — smooth opacity + gentle scale, not a strobe */
  @keyframes fwa-siren-pulse {
    0%, 100% { opacity: 1;    transform: scale(1);    }
    50%       { opacity: 0.55; transform: scale(1.15); }
  }
  :global(.fwa-pulse-icon) {
    animation: fwa-siren-pulse 1.2s ease-in-out infinite;
  }

  /* Respect reduced motion — kill pulse animation; JS also shows only State 1, no cycling. */
  @media (prefers-reduced-motion: reduce) {
    :global(.fwa-pulse-icon) { animation: none; }
  }

  /* Light-mode: black drop shadow (not orange) for separation from the page */
  :global(.light) #floating-whatsapp {
    box-shadow: 0 0 0 1px rgb(0 0 0 / 0.10), 0 8px 24px rgba(0,0,0,0.35);
  }
</style>

<script>
  import '@/scripts/floating-whatsapp.ts';
</script>
