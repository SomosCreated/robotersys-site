---
/**
 * StatsBand — "Nosso trabalho em números"
 *
 * A full-width band with a responsive grid of stat items.
 * Each stat: big number (count-up animated 0 → value on scroll) + mono label.
 * Background: surface, top/bottom borders.
 *
 * Props:
 *   stats   — array of { label: string; value: string }
 *   heading — localized section heading (defaults to PT for backward-compat)
 *
 * The numbers animate via src/scripts/countup.ts (IntersectionObserver,
 * reduced-motion safe; the markup already holds the final value for no-JS).
 *
 * PLACEHOLDER NOTE: stat values are provided by the parent and marked as
 * placeholders until the client confirms real numbers.
 */
interface Props {
  stats: { label: string; value: string }[];
  heading?: string;
  ariaLabel?: string;
}

const {
  stats,
  heading = 'Nosso trabalho em números',
  ariaLabel,
} = Astro.props;
---

<section aria-label={ariaLabel ?? heading} class="border-t border-b border-line bg-surface py-16 px-6 md:px-12 sys-reveal">
  <!-- Section heading -->
  <div class="max-w-7xl mx-auto">
    <div class="text-[10px] font-mono text-accent uppercase tracking-widest flex items-center gap-2 mb-10">
      <span class="w-1.5 h-1.5 bg-accent animate-pulse" aria-hidden="true"></span>
      // {heading}
    </div>

    <!-- Stats grid — 2 cols on mobile, auto-fill up to 5 on wide screens -->
    <div
      class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 divide-x divide-line"
      role="list"
      aria-label={ariaLabel ?? heading}
    >
      {stats.map((stat) => (
        <div
          class="flex flex-col items-center justify-center py-8 px-4 text-center first:border-l border-line sys-reveal"
          role="listitem"
        >
          <span
            class="text-4xl md:text-5xl font-medium text-strong tracking-tight mb-2 tabular-nums"
            data-countup
          >
            {stat.value}
          </span>
          <span class="text-xs font-mono text-muted uppercase tracking-widest leading-tight">
            {stat.label}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Count-up animation (IntersectionObserver-triggered, reduced-motion safe) -->
<script>
  import '@/scripts/countup';
</script>
