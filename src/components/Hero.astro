---
/**
 * Hero — poster-first (no autoplay video) for best LCP performance.
 *
 * Hero background: real factory/robot photo from current site (robotersys.com),
 * harvested in Phase 2.5. Gradient overlays ensure text readability in both
 * light and dark themes.
 *
 * PLACEHOLDER NOTE: Stat values (+1.200, +8.000, 24/7) are placeholder numbers.
 * Confirm with the client before going live.
 */
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import type { Locale } from '@/i18n/types';
import { t } from '@/i18n';
import heroPosterImg from '@/assets/robotersys/hero-robot.webp';

interface Props {
  locale?: Locale;
}
const { locale = 'pt' } = Astro.props;
---

<section
  id="hero"
  class="min-h-[750px] flex overflow-hidden bg-bg w-full border-line border-b relative items-center perspective-1000"
  aria-label="Introdução"
>
  <!-- ── Background layer: poster image (LCP) ── -->
  <div class="z-0 absolute inset-0 overflow-hidden">
    <!-- Real hero photo from current site (robotersys.com) — Phase 2.5 -->
    <Image
      id="hero-poster"
      src={heroPosterImg}
      alt=""
      aria-hidden="true"
      width={1600}
      height={900}
      class="pointer-events-none w-full h-full object-cover absolute inset-0 scale-105 transition-transform duration-75"
      fetchpriority="high"
      loading="eager"
      decoding="async"
    />

    <!-- Horizontal dark-left gradient (readability for left-column content) -->
    <div
      class="absolute inset-0 bg-gradient-to-r from-bg from-15% via-bg/90 to-transparent z-10 pointer-events-none"
      aria-hidden="true"
    ></div>

    <!-- Vertical bottom-vignette (grounds the section) -->
    <div
      class="absolute inset-0 bg-gradient-to-b from-transparent via-bg/20 to-bg z-10 pointer-events-none"
      aria-hidden="true"
    ></div>

    <!-- Spotlight overlay — driven by hero.ts mousemove -->
    <div
      id="hero-spotlight"
      class="absolute inset-0 z-10 opacity-0 transition-opacity duration-300 mix-blend-screen pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(1000px at 50% 50%, rgba(234, 88, 12, 0.25), transparent 60%);"
    ></div>

    <!-- Spotlight core (soft white highlight) -->
    <div
      id="hero-spotlight-core"
      class="absolute inset-0 z-10 opacity-0 transition-opacity duration-300 mix-blend-overlay pointer-events-none"
      aria-hidden="true"
      style="background: radial-gradient(400px at 50% 50%, rgba(255, 255, 255, 0.08), transparent 60%);"
    ></div>
  </div>

  <!-- ── Content grid ── -->
  <div class="container lg:px-12 grid grid-cols-1 lg:grid-cols-2 md:pt-32 md:pb-44 z-20 h-full mx-auto pt-24 px-6 pb-32 relative gap-x-12 gap-y-12 items-center">

    <!-- Left column: copy + CTAs -->
    <div class="flex flex-col justify-center max-w-2xl relative z-30">

      <!-- Kicker row: pulsing status dot + label -->
      <div class="flex items-center gap-3 mb-8 sys-reveal sys-rise" aria-label={t(locale, 'hero.kicker')}>
        <span class="relative flex h-2 w-2" aria-hidden="true">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-ok opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-ok"></span>
        </span>
        <span class="text-[10px] uppercase text-fg tracking-widest font-mono">
          {t(locale, 'hero.kicker')}
        </span>
      </div>

      <!-- H1 -->
      <h1
        class="text-5xl md:text-7xl lg:text-8xl font-medium text-strong uppercase tracking-tight leading-[0.9] mb-8 sys-reveal sys-rise sys-delay-100"
        id="hero-title"
      >
        {t(locale, 'hero.title')}
      </h1>

      <!-- Subtitle -->
      <p class="text-[1rem] md:text-lg text-fg leading-relaxed mb-10 max-w-md border-l-2 border-accent pl-4 sys-reveal sys-rise sys-delay-200">
        {t(locale, 'hero.subtitle')}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 mb-8 sys-reveal sys-rise sys-delay-300">
        <!-- Primary CTA -->
        <a
          href="/contato/"
          class="group bg-accent hover:bg-orange-500 text-white text-xs font-mono uppercase tracking-widest px-8 py-4 transition-all flex items-center justify-center gap-3 font-medium shadow-[0_0_20px_rgba(234,88,12,0.3)] hover:shadow-[0_0_40px_rgba(234,88,12,0.6)] relative overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          <div
            class="absolute inset-0 bg-gradient-to-r from-transparent via-white/40 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"
            aria-hidden="true"
          ></div>
          {t(locale, 'hero.cta_primary')}
          <Icon
            name="solar:arrow-right-linear"
            class="group-hover:translate-x-1 transition-transform"
            width={16}
            aria-hidden="true"
          />
        </a>

        <!-- Secondary CTA -->
        <a
          href="/servicos/"
          class="group bg-transparent border border-line hover:border-strong text-fg hover:text-strong text-xs font-mono uppercase tracking-widest px-8 py-4 transition-all flex items-center justify-center gap-3 font-medium backdrop-blur-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-strong focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
        >
          {t(locale, 'hero.cta_secondary')}
          <Icon
            name="solar:list-check-linear"
            class="group-hover:translate-x-1 transition-transform"
            width={16}
            aria-hidden="true"
          />
        </a>
      </div>
    </div>

    <!-- Right column: stat cards (telemetry-style) -->
    <!--
      PLACEHOLDER: Numbers below (+1.200, +8.000, 24/7) are placeholder values.
      Confirm real metrics with the client before launch.
    -->
    <div
      class="hidden lg:flex flex-col items-end justify-center relative h-full select-none"
      id="telemetry-container"
      aria-label="Métricas de serviço"
    >
      <div class="relative w-full max-w-sm perspective-1000 mt-12 mr-8">

        <!-- Card 1: Robôs atendidos (top-left offset) -->
        <div
          class="telemetry-card absolute -top-32 right-0 w-64 bg-bg/90 backdrop-blur-sm border border-line border-l-2 border-l-accent p-5 z-10 sys-reveal sys-slide-l sys-delay-300"
          data-depth="0.1"
        >
          <div class="flex justify-between items-center mb-3 border-b border-line pb-2">
            <span class="text-[9px] font-mono text-muted uppercase tracking-widest">
              {t(locale, 'hero.stat_robots_label')}
            </span>
            <Icon
              name="solar:programming-linear"
              class="text-accent animate-pulse"
              width={14}
              aria-hidden="true"
            />
          </div>
          <div class="text-3xl font-medium text-strong tracking-tight">
            {t(locale, 'hero.stat_robots_value')}
          </div>
        </div>

        <!-- Card 2: Intervenções realizadas (main / centre) -->
        <div
          class="telemetry-card relative w-80 bg-surface/95 backdrop-blur-sm border border-line p-6 z-20 shadow-2xl hover:border-accent/50 transition-colors pointer-events-auto hover:shadow-[0_0_30px_rgba(234,88,12,0.15)] sys-reveal sys-rise sys-delay-200"
          data-depth="0.2"
        >
          <!-- Left accent bar -->
          <div class="absolute -left-px top-6 bottom-6 w-0.5 bg-accent" aria-hidden="true"></div>

          <div class="flex justify-between items-start mb-6">
            <div>
              <div class="text-[10px] font-mono text-muted uppercase tracking-widest mb-1">
                {t(locale, 'hero.stat_interventions_label')}
              </div>
              <div class="text-3xl font-medium text-strong tracking-tight">
                {t(locale, 'hero.stat_interventions_value')}
              </div>
            </div>
            <div class="h-8 w-8 rounded-sm bg-accent/10 border border-accent/20 flex items-center justify-center" aria-hidden="true">
              <Icon name="solar:widget-3-linear" class="text-accent text-lg" width={18} />
            </div>
          </div>

          <div class="space-y-3">
            <div>
              <div class="text-[9px] font-mono text-muted uppercase mb-1">Taxa de sucesso</div>
              <div class="w-full bg-elevated h-1">
                <div class="bg-accent h-full w-[97%] relative">
                  <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1 h-2 bg-white animate-pulse" aria-hidden="true"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 3: Suporte 24/7 (bottom-right offset) -->
        <div
          class="telemetry-card absolute -bottom-24 right-8 w-64 bg-bg/90 backdrop-blur-sm border border-line p-4 z-10 sys-reveal sys-slide-l sys-delay-400"
          data-depth="0.15"
        >
          <div class="flex justify-between items-center mb-3">
            <span class="text-[9px] font-mono text-muted uppercase tracking-widest">
              {t(locale, 'hero.stat_support_label')}
            </span>
            <Icon
              name="solar:phone-calling-rounded-linear"
              class="text-accent"
              width={14}
              aria-hidden="true"
            />
          </div>
          <div class="text-3xl font-medium text-strong tracking-tight">
            {t(locale, 'hero.stat_support_value')}
          </div>
          <div class="mt-2 flex items-center gap-2">
            <span class="relative flex h-1.5 w-1.5" aria-hidden="true">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-ok opacity-75"></span>
              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-ok"></span>
            </span>
            <span class="text-[9px] font-mono text-ok uppercase tracking-widest">Ativo agora</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
