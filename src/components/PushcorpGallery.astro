---
/**
 * PushcorpGallery — multi-item sliding carousel of PushCorp operation photos.
 *
 * Layout: shows several slides at once — 3 per view on desktop (lg), 2 on tablet
 * (sm), 1 on mobile — and slides horizontally ONE item at a time.
 *
 * Behavior:
 * - Auto-advances every 4 s; pauses on hover/focus; wraps at the ends.
 * - Prev / Next buttons + dot indicators (one per reachable start position).
 * - prefers-reduced-motion: a static horizontal scroll-snap row is shown instead.
 * - Accessible: role="region", aria-roledescription="carousel", real <button>
 *   controls with aria-labels, aria-current on the active dot.
 * - astro:assets <Image>, eager for the first visible row, lazy for the rest.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Slide {
  src: ImageMetadata;
  alt: string;
}

interface Props {
  slides: Slide[];
  /** aria-label for the carousel region */
  ariaLabel?: string;
}

const { slides, ariaLabel = 'PushCorp photo gallery' } = Astro.props;
const total = slides.length;
---

<!-- Reduced-motion: static scroll-snap row (several visible per view) -->
<div
  class="motion-reduce:flex motion-reduce:gap-3 motion-reduce:overflow-x-auto motion-reduce:snap-x motion-reduce:snap-mandatory motion-safe:hidden"
  aria-label={ariaLabel}
  role="region"
>
  {slides.map((slide, i) => (
    <div class="flex-none w-[80%] sm:w-[46%] lg:w-[31%] snap-start overflow-hidden border border-line">
      <Image
        src={slide.src}
        alt={slide.alt}
        width={960}
        height={720}
        class="w-full aspect-[4/3] object-cover object-center"
        loading={i < 3 ? 'eager' : 'lazy'}
        decoding="async"
      />
    </div>
  ))}
</div>

<!-- Sliding carousel (hidden under reduced-motion) -->
<div
  class="motion-reduce:hidden"
  role="region"
  aria-label={ariaLabel}
  aria-roledescription="carousel"
  id="pc-gallery"
>
  <!-- Clipped viewport -->
  <div class="overflow-hidden" id="pc-viewport">
    <!-- Slide track: each slide is a 1/perView fraction of the viewport width -->
    <div
      id="pc-track"
      class="flex gap-3 transition-transform duration-500 ease-out will-change-transform"
    >
      {slides.map((slide, i) => (
        <div
          class="pc-slide flex-none w-full sm:w-[calc((100%_-_0.75rem)/2)] lg:w-[calc((100%_-_1.5rem)/3)] overflow-hidden border border-line bg-bg"
          role="group"
          aria-roledescription="slide"
          aria-label={`${i + 1} / ${total}`}
        >
          <Image
            src={slide.src}
            alt={slide.alt}
            width={960}
            height={720}
            class="w-full aspect-[4/3] object-cover object-center"
            loading={i < 3 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>
      ))}
    </div>
  </div>

  <!-- Controls: dots (left) + prev/next (right), below the viewport -->
  <div class="flex items-center justify-between gap-4 mt-4">
    <div class="flex flex-wrap gap-2" role="tablist" aria-label="Slide indicators">
      {slides.map((_, i) => (
        <button
          type="button"
          role="tab"
          data-dot={i}
          aria-label={`Go to slide ${i + 1}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-current={i === 0 ? 'true' : undefined}
          class:list={[
            'w-2 h-2 rounded-full transition-all duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface',
            i === 0 ? 'bg-accent scale-110' : 'bg-muted/40 hover:bg-muted/70',
          ]}
        ></button>
      ))}
    </div>

    <div class="flex gap-2 flex-shrink-0">
      <button
        id="pc-prev"
        type="button"
        aria-label="Previous slides"
        class="w-9 h-9 flex items-center justify-center bg-bg hover:bg-accent text-strong hover:text-white border border-line hover:border-accent transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-1 focus-visible:ring-offset-surface"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 18l-6-6 6-6" />
        </svg>
      </button>
      <button
        id="pc-next"
        type="button"
        aria-label="Next slides"
        class="w-9 h-9 flex items-center justify-center bg-bg hover:bg-accent text-strong hover:text-white border border-line hover:border-accent transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-1 focus-visible:ring-offset-surface"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6" />
        </svg>
      </button>
    </div>
  </div>
</div>

<script define:vars={{ total }}>
  (function () {
    const gallery = document.getElementById('pc-gallery');
    if (!gallery) return;

    const track = document.getElementById('pc-track');
    const slideEls = Array.from(gallery.querySelectorAll('.pc-slide'));
    const dots = Array.from(gallery.querySelectorAll('[data-dot]'));
    const prevBtn = document.getElementById('pc-prev');
    const nextBtn = document.getElementById('pc-next');

    let current = 0;
    let timer = null;

    function perView() {
      if (window.matchMedia('(min-width: 1024px)').matches) return 3;
      if (window.matchMedia('(min-width: 640px)').matches) return 2;
      return 1;
    }
    function maxIndex() {
      return Math.max(0, total - perView());
    }
    // Item pitch (slide width + gap), measured from the first two slides so it
    // stays correct across breakpoints regardless of the actual gap value.
    function step() {
      if (slideEls.length < 2) {
        return slideEls[0] ? slideEls[0].getBoundingClientRect().width : 0;
      }
      return slideEls[1].getBoundingClientRect().left - slideEls[0].getBoundingClientRect().left;
    }

    function render() {
      const mx = maxIndex();
      if (current > mx) current = mx;
      if (current < 0) current = 0;
      track.style.transform = 'translateX(' + (-(current * step())) + 'px)';
      dots.forEach(function (dot, i) {
        dot.style.display = i <= mx ? '' : 'none';
        const active = i === current;
        dot.setAttribute('aria-selected', active ? 'true' : 'false');
        if (active) {
          dot.setAttribute('aria-current', 'true');
          dot.classList.add('bg-accent', 'scale-110');
          dot.classList.remove('bg-muted/40', 'hover:bg-muted/70');
        } else {
          dot.removeAttribute('aria-current');
          dot.classList.remove('bg-accent', 'scale-110');
          dot.classList.add('bg-muted/40', 'hover:bg-muted/70');
        }
      });
    }

    function goTo(idx) {
      const mx = maxIndex();
      if (idx < 0) idx = mx;        // wrap to the last position
      else if (idx > mx) idx = 0;   // wrap back to the start
      current = idx;
      render();
    }

    function startAuto() {
      stopAuto();
      timer = setInterval(function () { goTo(current + 1); }, 4000);
    }
    function stopAuto() {
      if (timer !== null) { clearInterval(timer); timer = null; }
    }

    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); startAuto(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); startAuto(); });
    dots.forEach(function (dot, i) {
      dot.addEventListener('click', function () { goTo(Math.min(i, maxIndex())); startAuto(); });
    });

    gallery.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft') { goTo(current - 1); startAuto(); }
      else if (e.key === 'ArrowRight') { goTo(current + 1); startAuto(); }
    });

    // Pause on hover / focus (WCAG: auto-updating content must be pausable)
    gallery.addEventListener('mouseenter', stopAuto);
    gallery.addEventListener('mouseleave', startAuto);
    gallery.addEventListener('focusin', stopAuto);
    gallery.addEventListener('focusout', startAuto);

    // Recompute geometry on resize (perView + step both change)
    let raf = null;
    window.addEventListener('resize', function () {
      if (raf) cancelAnimationFrame(raf);
      raf = requestAnimationFrame(render);
    });

    render();
    startAuto();
  })();
</script>
