---
/**
 * CellGallery — grid of robotic cell cards for the Sistemas Robóticos page.
 *
 * Each cell card: photo + title + description + "Saiba mais" CTA.
 * Real photos from the current site (robotersys.com) are loaded via astro:assets.
 *
 * Props: cells — array of { title, desc, href, fig, imgSrc?, imgAlt? }
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface CellItem {
  fig: string;
  title: string;
  desc: string;
  /** Link target for "Saiba mais" — defaults to /contato/ until individual pages exist */
  href?: string;
  /** Label for the "Saiba mais" button */
  ctaLabel?: string;
  /** Real photo for this cell (imported via astro:assets). If absent, falls back to placeholder. */
  imgSrc?: ImageMetadata;
  /** Alt text for the image */
  imgAlt?: string;
}

interface Props {
  cells: CellItem[];
  ctaLabel?: string;
}

const { cells, ctaLabel = 'Saiba mais' } = Astro.props;
---

<div
  class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 border-t border-l border-line"
  role="list"
  aria-label="Galeria de células robotizadas"
>
  {cells.map((cell) => (
    <article
      class="border-b border-r border-line flex flex-col group hover:bg-elevated/30 transition-colors"
      role="listitem"
    >
      <!-- Image area -->
      <div
        class="aspect-video bg-elevated/60 border-b border-line relative overflow-hidden"
      >
        {cell.imgSrc ? (
          <Image
            src={cell.imgSrc}
            alt={cell.imgAlt ?? cell.title}
            width={480}
            height={270}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            decoding="async"
          />
        ) : (
          /* // PLACEHOLDER (não encontrado no site atual) */
          <div class="w-full h-full flex flex-col items-center justify-center gap-2" aria-hidden="true">
            <div class="absolute inset-0 opacity-[0.04] bg-grid pointer-events-none"></div>
            <span class="text-[9px] font-mono text-muted uppercase tracking-widest z-10">
              // PLACEHOLDER
            </span>
            <span class="text-[9px] font-mono text-muted uppercase tracking-widest z-10">
              {cell.fig}
            </span>
          </div>
        )}
      </div>

      <!-- Content -->
      <div class="p-6 flex flex-col gap-3 flex-1">
        <!-- Fig tag -->
        <span class="text-[9px] font-mono text-muted uppercase tracking-widest border border-line px-2 py-0.5 self-start bg-bg">
          {cell.fig}
        </span>

        <!-- Title -->
        <h3 class="text-sm font-medium text-strong uppercase tracking-tight leading-snug group-hover:text-accent transition-colors">
          {cell.title}
        </h3>

        <!-- Description -->
        <p class="text-sm text-muted font-mono leading-relaxed flex-1">
          {cell.desc}
        </p>

        <!-- CTA -->
        <a
          href={cell.href ?? '/contato/'}
          class="mt-auto text-[10px] font-mono uppercase tracking-widest text-accent hover:text-orange-400 transition-colors flex items-center gap-1.5 self-start focus-visible:outline-none focus-visible:underline"
          aria-label={`${cell.ctaLabel ?? ctaLabel}: ${cell.title}`}
        >
          {cell.ctaLabel ?? ctaLabel}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="10"
            height="10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </a>
      </div>
    </article>
  ))}
</div>
