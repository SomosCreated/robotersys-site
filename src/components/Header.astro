---
import { Icon } from 'astro-icon/components';
import type { Locale } from '@/i18n/types';
import type { PageKey } from '@/i18n/routes';
import { LOCALES, LOCALE_LABELS, localizedPath } from '@/i18n/routes';
import { t } from '@/i18n';
import ThemeToggle from '@/components/ThemeToggle.astro';
import LanguageSwitcher from '@/components/LanguageSwitcher.astro';

interface Props {
  locale?: Locale;
  currentPageKey?: PageKey;
}
const { locale = 'pt', currentPageKey = 'home' } = Astro.props;

type NavChild = { label: string; href: string };
type NavItem = { key: string; href: string; children?: NavChild[] };

// Sistemas mega-menu sub-pages: the 3 robotic cells + PushCorp (now a Sistemas sub-page).
const sistemasChildren: NavChild[] = [
  { label: t(locale, 'sistemas.cell1_title'), href: localizedPath('celulaPaletizacao1', locale) },
  { label: t(locale, 'sistemas.cell2_title'), href: localizedPath('celulaPaletizacao2', locale) },
  { label: t(locale, 'sistemas.cell3_title'), href: localizedPath('celulasManipulacao', locale) },
  { label: t(locale, 'nav.pushcorp'),         href: localizedPath('pushcorp', locale) },
];

const navItems: NavItem[] = [
  { key: 'nav.services', href: localizedPath('servicos', locale) },
  { key: 'nav.parts',    href: localizedPath('pecas', locale) },
  { key: 'nav.systems',  href: localizedPath('sistemas', locale), children: sistemasChildren },
  { key: 'nav.about',    href: localizedPath('sobre', locale) },
  { key: 'nav.careers',  href: localizedPath('carreiras', locale) },
  // {/* Phase 4 */} — blog not yet localized; special-cased until blog pages exist per locale
  { key: 'nav.blog',     href: locale === 'pt' ? '/blog/' : `/${locale}/blog/` },
];
---

<!-- header -->
<header class="relative z-50 h-16 border-b border-line bg-bg/95 backdrop-blur-sm flex items-center sticky top-0">

  <!-- logo (far left) -->
  <div class="flex items-center h-full pl-6 pr-8 border-r border-line bg-bg">
    <a class="flex items-center group" href={localizedPath('home', locale)}>
      <span class="text-2xl font-medium text-strong tracking-tight">
        RoboterSys<span class="text-accent">.</span>
      </span>
    </a>
  </div>

  <!-- spacer -->
  <div class="flex-1"></div>

  <!-- desktop nav + controls (right side) -->
  <div class="hidden lg:flex items-center h-full border-l border-line bg-bg">
    <!-- nav links -->
    <nav class="flex h-full items-center" aria-label={t(locale, 'nav.aria_main')}>
      {navItems.map((item) => (
        item.children ? (
          <!-- Dropdown / mega-menu parent (Sistemas) — opens on hover and keyboard focus -->
          <div class="relative h-full group/dd">
            <a
              class="flex items-center gap-1.5 px-5 h-full text-[10px] font-mono uppercase tracking-widest text-fg hover:text-strong hover:bg-elevated/50 transition-colors border-r border-line/50 relative focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
              href={item.href}
              aria-haspopup="true"
            >
              {t(locale, item.key)}
              <Icon
                name="solar:alt-arrow-down-linear"
                width={10}
                class="opacity-70 group-hover/dd:rotate-180 group-focus-within/dd:rotate-180 transition-transform"
                aria-hidden="true"
              />
              <div class="absolute bottom-0 left-0 w-full h-[2px] bg-accent scale-x-0 group-hover/dd:scale-x-100 group-focus-within/dd:scale-x-100 transition-transform origin-left" aria-hidden="true"></div>
            </a>
            <!-- Mega-menu panel -->
            <div class="absolute top-full left-0 min-w-[280px] border border-line bg-bg shadow-2xl shadow-black/30 opacity-0 invisible translate-y-1 group-hover/dd:opacity-100 group-hover/dd:visible group-hover/dd:translate-y-0 group-focus-within/dd:opacity-100 group-focus-within/dd:visible group-focus-within/dd:translate-y-0 transition-all duration-150 z-50">
              <div class="px-5 pt-3 pb-2 text-[9px] font-mono text-muted uppercase tracking-widest border-b border-line/50">
                {t(locale, item.key)}
              </div>
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="flex items-center gap-2.5 px-5 py-3.5 text-[10px] font-mono uppercase tracking-widest text-fg hover:text-strong hover:bg-elevated border-b border-line/50 last:border-b-0 transition-colors focus-visible:outline-none focus-visible:bg-elevated focus-visible:text-strong"
                >
                  <span class="w-1 h-1 bg-accent flex-shrink-0" aria-hidden="true"></span>
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            class="flex items-center px-5 h-full text-[10px] font-mono uppercase tracking-widest text-fg hover:text-strong hover:bg-elevated/50 transition-colors border-r border-line/50 relative group focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent"
            href={item.href}
          >
            {t(locale, item.key)}
            <div class="absolute bottom-0 left-0 w-full h-[2px] bg-accent scale-x-0 group-hover:scale-x-100 transition-transform origin-left" aria-hidden="true"></div>
          </a>
        )
      ))}
    </nav>
    <!-- Theme toggle -->
    <div class="border-r border-line h-full flex items-center">
      <ThemeToggle />
    </div>
    <!-- Language switcher -->
    <div class="border-r border-line h-full flex items-center">
      <LanguageSwitcher currentLocale={locale} currentPageKey={currentPageKey} />
    </div>
    <!-- CTA -->
    <a
      class="h-full px-8 bg-accent text-white text-[10px] font-mono uppercase tracking-widest hover:bg-orange-500 transition-all flex items-center gap-2 group shadow-[inset_0_0_20px_rgba(0,0,0,0.2)] font-medium focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-inset"
      href={localizedPath('contato', locale)}
    >
      {t(locale, 'header.cta')}
      <Icon
        name="solar:arrow-right-linear"
        class="group-hover:translate-x-1 transition-transform"
        width={14}
        aria-hidden="true"
      />
    </a>
  </div>

  <!-- mobile right side: theme toggle + hamburger -->
  <div class="md:hidden flex items-center h-full">
    <!-- Theme toggle (mobile) -->
    <div class="border-l border-line h-full flex items-center">
      <ThemeToggle />
    </div>
    <!-- Hamburger -->
    <button
      class="p-0 w-16 h-full text-fg hover:text-strong border-l border-line bg-bg flex items-center justify-center transition-colors hover:bg-elevated focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-inset focus-visible:ring-accent"
      id="mobile-menu-btn"
      aria-label={t(locale, 'nav.aria_open')}
      data-label-open={t(locale, 'nav.aria_open')}
      data-label-close={t(locale, 'nav.aria_close')}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <Icon name="solar:hamburger-menu-linear" width={24} aria-hidden="true" />
    </button>
  </div>
</header>

<!-- mobile menu panel -->
<div
  class="fixed inset-x-0 top-16 bottom-0 z-40 bg-bg transform translate-x-full transition-transform duration-300 md:hidden flex flex-col border-t border-line overflow-y-auto"
  id="mobile-menu"
  aria-hidden="true"
>
  <div class="flex flex-col p-6 space-y-4">
    <!-- mobile CTA -->
    <a
      class="w-full py-4 bg-accent text-white text-xs font-mono uppercase tracking-widest hover:bg-orange-500 flex items-center justify-center gap-2 transition-all shadow-lg shadow-orange-900/20 font-medium"
      href={localizedPath('contato', locale)}
    >
      {t(locale, 'header.cta')}
      <Icon name="solar:arrow-right-linear" width={16} aria-hidden="true" />
    </a>

    <!-- mobile language switcher -->
    <div class="border border-line bg-elevated/20 flex items-center px-4 py-2 gap-2">
      <Icon name="solar:global-linear" width={14} aria-hidden="true" class="text-muted shrink-0" />
      <span class="text-[10px] font-mono uppercase tracking-widest text-muted">{t(locale, 'nav.language')}</span>
      <div class="ml-auto flex gap-1">
        {LOCALES.map((loc) => {
          const isActive = loc === locale;
          return (
            <a
              href={localizedPath(currentPageKey, loc)}
              aria-current={isActive ? 'true' : undefined}
              class:list={[
                'px-2 py-1 text-[10px] font-mono uppercase tracking-widest border border-line transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent',
                isActive
                  ? 'bg-accent text-white border-accent'
                  : 'text-fg hover:text-strong hover:bg-elevated',
              ]}
            >
              {LOCALE_LABELS[loc]}
            </a>
          );
        })}
      </div>
    </div>

    <!-- mobile nav links -->
    <div class="flex flex-col border border-line bg-elevated/20">
      {navItems.map((item, idx) => (
        item.children ? (
          <div class="border-b border-line last:border-b-0">
            <button
              type="button"
              class="w-full flex items-center justify-between p-4 text-xs font-mono uppercase tracking-widest text-fg hover:text-strong hover:bg-elevated transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-inset focus-visible:ring-accent"
              data-submenu-toggle
              aria-expanded="false"
              aria-controls={`submenu-${idx}`}
            >
              {t(locale, item.key)}
              <Icon
                name="solar:alt-arrow-down-linear"
                class="transition-transform text-accent"
                data-submenu-chevron
                width={14}
                aria-hidden="true"
              />
            </button>
            <div id={`submenu-${idx}`} class="hidden flex-col bg-bg/40" data-submenu>
              <!-- Overview link (the Sistemas page itself) + the sub-pages -->
              <a
                href={item.href}
                class="flex items-center gap-2 py-3 pl-8 pr-4 border-t border-line/40 text-[11px] font-mono uppercase tracking-widest text-muted hover:text-strong hover:bg-elevated transition-colors"
              >
                <span class="w-1 h-1 bg-accent flex-shrink-0" aria-hidden="true"></span>
                {t(locale, item.key)}
              </a>
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="flex items-center gap-2 py-3 pl-8 pr-4 border-t border-line/40 text-[11px] font-mono uppercase tracking-widest text-muted hover:text-strong hover:bg-elevated transition-colors"
                >
                  <span class="w-1 h-1 bg-accent flex-shrink-0" aria-hidden="true"></span>
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            class="flex items-center justify-between p-4 border-b border-line text-xs font-mono uppercase tracking-widest text-fg hover:text-strong hover:bg-elevated transition-colors group last:border-b-0"
            href={item.href}
          >
            {t(locale, item.key)}
            <Icon
              name="solar:alt-arrow-right-linear"
              class="opacity-0 group-hover:opacity-100 transition-opacity text-accent"
              width={14}
              aria-hidden="true"
            />
          </a>
        )
      ))}
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('translate-x-full');
      const labelOpen = btn.dataset.labelOpen ?? 'Open navigation menu';
      const labelClose = btn.dataset.labelClose ?? 'Close navigation menu';
      if (isOpen) {
        menu.classList.add('translate-x-full');
        menu.setAttribute('aria-hidden', 'true');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', labelOpen);
      } else {
        menu.classList.remove('translate-x-full');
        menu.setAttribute('aria-hidden', 'false');
        btn.setAttribute('aria-expanded', 'true');
        btn.setAttribute('aria-label', labelClose);
      }
    });
  }

  // Mobile submenu accordions (Sistemas mega-menu on mobile)
  document.querySelectorAll('[data-submenu-toggle]').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const wrapper = toggle.parentElement;
      const panel = wrapper?.querySelector('[data-submenu]');
      const chevron = toggle.querySelector('[data-submenu-chevron]');
      if (!panel) return;
      const willOpen = panel.classList.contains('hidden');
      panel.classList.toggle('hidden', !willOpen);
      toggle.setAttribute('aria-expanded', String(willOpen));
      chevron?.classList.toggle('rotate-180', willOpen);
    });
  });
</script>
