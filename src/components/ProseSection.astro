---
/**
 * ProseSection — a content/prose block for long-form readable text.
 *
 * Layout:
 *  - Optional kicker (SectionLabel) + optional title heading
 *  - <slot> for rich prose content (paragraphs, inline markup)
 *
 * Typography:
 *  - Body text: text-zinc-300 at text-fg/text-lg, font-sans (Ubuntu, readable body),
 *    generous line-height (leading-relaxed) and max-w for good measure.
 *  - Headings inside slot should use prose-heading class (text-white uppercase).
 *
 * WCAG AA: body text-zinc-300 (≥7:1 on #050505), headings text-white.
 * prefers-reduced-motion: no transitions in this component.
 */
import SectionLabel from '@/components/SectionLabel.astro';

interface Props {
  /** Optional mono kicker label (rendered via SectionLabel) */
  kicker?: string;
  /** Optional section heading (h2) */
  title?: string;
  /** Optional aria label for the section */
  ariaLabel?: string;
}

const { kicker, title, ariaLabel } = Astro.props;
const headingId = title ? `prose-${title.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}` : undefined;
---

<section
  class="py-16 border-b border-line bg-bg"
  aria-labelledby={headingId ?? ariaLabel ? undefined : undefined}
  aria-label={!headingId && ariaLabel ? ariaLabel : undefined}
>
  <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
    {kicker && <SectionLabel text={kicker} />}

    {title && (
      <h2
        id={headingId}
        class="text-2xl md:text-3xl font-medium text-strong uppercase tracking-tight leading-tight mb-8 sys-reveal sys-rise"
      >
        {title}
      </h2>
    )}

    <!-- Prose content slot — text-zinc-300 for all flowing text -->
    <div class="prose-content space-y-5">
      <slot />
    </div>
  </div>
</section>

<!--
  Slot content is authored in the PARENT component, so Astro's scoping would not
  reach it (same gotcha as the blog prose). These rules are global, scoped by the
  unique `.prose-content` class so they only style ProseSection content.
-->
<style is:global>
  .prose-content p {
    font-family: var(--font-sans, ui-sans-serif, system-ui);
    font-size: 0.875rem; /* text-sm */
    line-height: 1.75;   /* leading-relaxed */
    color: rgb(var(--color-fg));
    max-width: 65ch;
  }

  .prose-content strong {
    color: rgb(var(--color-strong));
    font-weight: 500;
  }

  .prose-content em {
    color: rgb(var(--color-accent));
    font-style: normal;
  }

  .prose-content a {
    color: rgb(var(--color-accent));
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 150ms;
  }

  .prose-content a:hover {
    color: rgb(var(--color-strong));
  }

  /* Inline subheadings inside prose slot */
  .prose-content h3 {
    font-size: 0.875rem;
    font-weight: 500;
    color: rgb(var(--color-strong));
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  /* Unordered lists */
  .prose-content ul {
    list-style: none;
    padding: 0;
    margin-bottom: 1.25rem;
  }

  .prose-content ul li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-family: var(--font-sans, ui-sans-serif, system-ui);
    font-size: 0.875rem;
    line-height: 1.75;
    color: rgb(var(--color-fg));
    margin-bottom: 0.5rem;
  }

  .prose-content ul li::before {
    content: '—';
    color: rgb(var(--color-accent));
    flex-shrink: 0;
    margin-top: 0.1em;
  }

  /* Ordered lists */
  .prose-content ol {
    counter-reset: list;
    padding: 0;
    margin-bottom: 1.25rem;
  }

  .prose-content ol li {
    counter-increment: list;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.875rem;
    line-height: 1.75;
    color: rgb(var(--color-fg));
    margin-bottom: 0.5rem;
  }

  .prose-content ol li::before {
    content: counter(list) '.';
    color: rgb(var(--color-accent));
    flex-shrink: 0;
    font-weight: 500;
    min-width: 1.5rem;
  }

  /* Tables (e.g. the cookie inventory) */
  .prose-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 0.5rem 0 1.25rem;
    font-size: 0.8125rem;
  }

  .prose-content th,
  .prose-content td {
    border: 1px solid rgb(var(--color-line));
    padding: 0.5rem 0.75rem;
    text-align: left;
    vertical-align: top;
  }

  .prose-content th {
    color: rgb(var(--color-strong));
    background: rgb(var(--color-surface));
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.75rem;
  }

  .prose-content code {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.8125rem;
    background: rgb(var(--color-surface));
    border: 1px solid rgb(var(--color-line));
    padding: 0.1rem 0.35rem;
    color: rgb(var(--color-accent));
  }
</style>
