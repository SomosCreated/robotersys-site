---
/**
 * Privacidade page template — locale-aware shell.
 *
 * Hero + meta vêm do i18n; o CORPO da política é um componente por idioma
 * (src/page-templates/legal/privacy.<locale>.astro), para cada língua ter um
 * documento devidamente traduzido (não mais o corpo PT repetido em todas).
 *
 * MINUTA — revisão jurídica recomendada. ÚNICO placeholder: o CNPJ.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import { t } from '@/i18n';
import type { Locale } from '@/i18n/types';
import { localizedPath } from '@/i18n/routes';

import PrivacyPt from '@/page-templates/legal/privacy.pt.astro';
import PrivacyEn from '@/page-templates/legal/privacy.en.astro';
import PrivacyEs from '@/page-templates/legal/privacy.es.astro';
import PrivacyDe from '@/page-templates/legal/privacy.de.astro';

interface Props { locale: Locale; }
const { locale } = Astro.props;

const bodies: Record<Locale, typeof PrivacyPt> = {
  pt: PrivacyPt,
  en: PrivacyEn,
  es: PrivacyEs,
  de: PrivacyDe,
};
const Body = bodies[locale] ?? PrivacyPt;

const crumbs = [
  { label: t(locale, 'legal.privacy_breadcrumb_home'), href: localizedPath('home', locale) },
  { label: t(locale, 'legal.privacy_breadcrumb_page'), href: localizedPath('privacidade', locale) },
];
---

<BaseLayout
  title={t(locale, 'legal.privacy_page_title')}
  description={t(locale, 'legal.privacy_meta_description')}
  locale={locale}
  pageKey="privacidade"
>
  <PageHero
    kicker={t(locale, 'legal.privacy_hero_kicker')}
    title={t(locale, 'legal.privacy_hero_title')}
    crumbs={crumbs}
  />

  <Body locale={locale} />
</BaseLayout>

<script>
  import '@/scripts/reveal';
</script>
