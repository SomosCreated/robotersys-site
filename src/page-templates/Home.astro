---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import SectionLabel from '@/components/SectionLabel.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import ComparisonTable from '@/components/ComparisonTable.astro';
import StatsBand from '@/components/StatsBand.astro';
import Emergency24hCTA from '@/components/Emergency24hCTA.astro';
import ContactForm from '@/components/ContactForm.astro';
import BlogCard from '@/components/BlogCard.astro';
import ClientsCarousel from '@/components/ClientsCarousel.astro';
import YouTubeFacade from '@/components/YouTubeFacade.astro';
import { Icon } from 'astro-icon/components';
import { t } from '@/i18n';
import { brandHtml } from '@/lib/brand';
import type { Locale } from '@/i18n/types';
import { localizedPath } from '@/i18n/routes';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const services = [
  {
    fig: 'FIG. 01',
    icon: 'solar:bolt-circle-linear',
    title: t(locale, 'services.s1_title'),
    desc: t(locale, 'services.s1_desc'),
  },
  {
    fig: 'FIG. 02',
    icon: 'solar:shield-check-linear',
    title: t(locale, 'services.s2_title'),
    desc: t(locale, 'services.s2_desc'),
  },
  {
    fig: 'FIG. 03',
    icon: 'solar:box-linear',
    title: t(locale, 'services.s3_title'),
    desc: t(locale, 'services.s3_desc'),
  },
  {
    fig: 'FIG. 04',
    icon: 'solar:refresh-circle-linear',
    title: t(locale, 'services.s4_title'),
    desc: t(locale, 'services.s4_desc'),
  },
  {
    fig: 'FIG. 05',
    icon: 'solar:diploma-linear',
    title: t(locale, 'services.s5_title'),
    desc: t(locale, 'services.s5_desc'),
  },
  {
    fig: 'FIG. 06',
    icon: 'solar:settings-linear',
    title: t(locale, 'services.s6_title'),
    desc: t(locale, 'services.s6_desc'),
  },
];

// ── Comparison table: "Por que escolher a RoboterSys" ──
// Columns: RoboterSys (highlight) · Não especializadas · Fabricante.
// The ✓/✗ matrix lives here (data), only the text is translated via i18n.
const compareColumns = [
  { label: t(locale, 'compare.col_rs'),     sublabel: t(locale, 'compare.best'), highlight: true },
  { label: t(locale, 'compare.col_others') },
  { label: t(locale, 'compare.col_maker') },
];
const compareRows = [
  { feature: t(locale, 'compare.r1'), cells: ['yes', 'no',  'yes'] as const },
  { feature: t(locale, 'compare.r2'), cells: ['yes', 'yes', 'no']  as const },
  { feature: t(locale, 'compare.r3'), cells: ['yes', 'yes', 'no']  as const },
  { feature: t(locale, 'compare.r4'), cells: ['yes', 'yes', 'no']  as const },
  { feature: t(locale, 'compare.r5'), cells: ['yes', 'no',  'yes'] as const },
  { feature: t(locale, 'compare.r6'), cells: ['yes', 'no',  'yes'] as const },
  { feature: t(locale, 'compare.r7'), cells: ['yes', 'no',  'yes'] as const },
];

// PLACEHOLDER NOTE: stat values come from pt.ts and are placeholders.
// Confirm real numbers with the client before going live.
const stats = [
  { label: t(locale, 'stats.clients_label'),       value: t(locale, 'stats.clients_value') },
  { label: t(locale, 'stats.robots_label'),         value: t(locale, 'stats.robots_value') },
  { label: t(locale, 'stats.interventions_label'),  value: t(locale, 'stats.interventions_value') },
  { label: t(locale, 'stats.support_calls_label'),  value: t(locale, 'stats.support_calls_value') },
  { label: t(locale, 'stats.lines_label'),          value: t(locale, 'stats.lines_value') },
];

// clientLogos array removed — logos now rendered by ClientsCarousel.astro (locale-aware)

// Phase 4 — real blog posts from content collection
const allBlogPosts = await getCollection('blog', (entry) =>
  entry.data.language === locale && !entry.data.draft
);
const latestPosts = allBlogPosts
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const blogHref = localizedPath('blog', locale);
---

<BaseLayout
  title={`RoboterSys — ${t(locale, 'hero.title')}`}
  description={t(locale, 'hero.subtitle')}
  locale={locale}
  pageKey="home"
>
  <!-- Hero (LCP — keep first) -->
  <Hero locale={locale} />

  <!-- ── Serviços ── -->
  <!-- bg-white in light (pure white, not the #fafafa near-white) / bg-bg keeps dark identity in dark -->
  <section
    class="border-b border-line py-20 px-6 md:px-12 bg-white dark:bg-bg"
    aria-labelledby="services-heading"
  >
    <div class="max-w-7xl mx-auto">
      <SectionLabel text={t(locale, 'services.section_label')} />

      <!-- spotlight-grid: CSS + spotlight.ts set --mouse-x/--mouse-y on each .spotlight-card -->
      <div
        id="services-heading"
        class="sr-only"
      >
        Serviços RoboterSys
      </div>
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 spotlight-grid border-t border-l border-line sys-reveal"
        role="list"
        aria-label="Lista de serviços"
      >
        {services.map((service) => (
          <div role="listitem">
            <ServiceCard
              fig={service.fig}
              icon={service.icon}
              title={service.title}
              desc={service.desc}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Por que RoboterSys (comparação) ── -->
  <!-- bg-surface alternates against the white (light) / bg (dark) Services section above -->
  <section
    class="border-b border-line py-20 px-6 md:px-12 bg-surface sys-reveal"
    aria-labelledby="compare-heading"
  >
    <div class="max-w-7xl mx-auto">
      <SectionLabel text={t(locale, 'compare.label')} />
      <h2
        id="compare-heading"
        class="text-2xl md:text-3xl font-medium text-strong uppercase tracking-tight leading-tight mb-10 sys-reveal sys-rise"
        set:html={brandHtml(t(locale, 'compare.heading'))}
      ></h2>

      <ComparisonTable
        caption={t(locale, 'compare.heading')}
        columns={compareColumns}
        rows={compareRows}
        yesLabel={t(locale, 'compare.yes')}
        noLabel={t(locale, 'compare.no')}
        scrollHint={t(locale, 'compare.scroll_hint')}
        compact
      />
    </div>
  </section>

  <!-- ── Clientes (carrossel full-bleed, largura total) ── -->
  <section
    class="border-b border-line py-20 bg-bg sys-reveal"
    aria-labelledby="clients-heading"
  >
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <SectionLabel text={t(locale, 'home.clients_section_label')} />
      <h2
        id="clients-heading"
        class="text-2xl md:text-3xl font-medium text-strong uppercase tracking-tight leading-tight mb-4 sys-reveal sys-rise"
      >
        {t(locale, 'home.clients_heading')}
      </h2>
      <p class="text-sm text-muted leading-relaxed mb-10 max-w-xl">
        {t(locale, 'home.clients_body')}
      </p>
    </div>

    <!-- Full-bleed marquee: edge-to-edge white band (largura completa do site) -->
    <ClientsCarousel locale={locale} />
  </section>

  <!-- ── Quem somos (texto + vídeo em 2 colunas) — logo após Clientes ── -->
  <section class="py-16 border-b border-line bg-bg" aria-labelledby="home-about-heading">
    <div class="container mx-auto px-6 lg:px-12 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

        <!-- Col 1: texto -->
        <div>
          <SectionLabel text={t(locale, 'home.about_section_label')} />
          <h2
            id="home-about-heading"
            class="text-2xl md:text-3xl font-medium text-strong uppercase tracking-tight leading-tight mb-6 sys-reveal sys-rise"
          >
            {t(locale, 'home.about_heading')}
          </h2>
          <div class="space-y-5 text-sm text-fg leading-relaxed max-w-prose">
            <p>{t(locale, 'home.about_p1')}</p>
            <p>{t(locale, 'home.about_p2')}</p>
          </div>
          <div class="mt-6">
            <a
              href={localizedPath('sobre', locale)}
              class="inline-flex items-center gap-2 text-xs font-mono text-accent hover:text-orange-400 uppercase tracking-widest transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent group"
            >
              {t(locale, 'home.about_cta')}
              <Icon
                name="solar:arrow-right-linear"
                class="motion-safe:group-hover:translate-x-1 transition-transform"
                width={14}
                height={14}
                aria-hidden="true"
              />
            </a>
          </div>
        </div>

        <!-- Col 2: vídeo institucional -->
        <div class="sys-reveal">
          <div class="text-[10px] font-mono text-accent uppercase tracking-widest flex items-center gap-2 mb-4">
            <span class="w-1.5 h-1.5 bg-accent animate-pulse" aria-hidden="true"></span>
            // {t(locale, 'home.video_label')}
          </div>
          <YouTubeFacade
            videoId="9LfO5J9cM2I"
            title={t(locale, 'home.video_heading')}
            playLabel={t(locale, 'home.video_play_label')}
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ── Estatísticas ── -->
  <StatsBand
    stats={stats}
    heading={t(locale, 'stats.section_label')}
    ariaLabel={t(locale, 'stats.section_label')}
  />

  <!-- ── GPTW Recognition Band ── -->
  <!--
    PLACEHOLDER NOTE: GPTW seal below is a placeholder.
    Replace with real GPTW seal/logo image (confirm asset with the client).
  -->
  <section
    class="border-b border-line py-16 px-6 md:px-12 bg-surface sys-reveal"
    aria-labelledby="gptw-heading"
  >
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-8 md:gap-16">

      <!-- GPTW seal — real image from current site (robotersys.com) — displayed at 2× size -->
      <div class="flex-shrink-0">
        <img
          src="/robotersys/img/GPTW-Selos.webp"
          alt="Selo Great Place to Work — RoboterSys certificada GPTW"
          width="240"
          height="240"
          loading="lazy"
          decoding="async"
          class="w-48 h-auto object-contain"
        />
      </div>

      <!-- GPTW copy -->
      <div class="flex-1">
        <SectionLabel text={t(locale, 'home.gptw_section_label')} />
        <h2
          id="gptw-heading"
          class="text-xl md:text-2xl lg:text-3xl font-medium text-strong uppercase tracking-tight leading-tight mb-3 sys-reveal sys-rise"
        >
          {t(locale, 'home.gptw_heading')}
        </h2>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-xs font-mono text-ok uppercase tracking-widest border border-green-800/50 bg-green-950/20 px-3 py-1">
            {t(locale, 'home.gptw_years')}
          </span>
        </div>
        <p class="text-sm text-muted leading-relaxed max-w-xl">
          {t(locale, 'home.gptw_body')}
        </p>
      </div>
    </div>
  </section>

  <!-- (Quem somos + vídeo foi movido para logo após a seção Clientes, acima.) -->

  <!-- ── Blog Teaser ── -->
  {latestPosts.length > 0 && (
    <section
      class="border-b border-line py-20 px-6 md:px-12 bg-surface sys-reveal"
      aria-labelledby="blog-heading"
    >
      <div class="max-w-7xl mx-auto">
        <SectionLabel text={t(locale, 'home.blog_section_label')} />

        <div class="flex items-end justify-between gap-4 mb-10">
          <h2
            id="blog-heading"
            class="text-2xl md:text-3xl font-medium text-strong uppercase tracking-tight leading-tight sys-reveal sys-rise"
          >
            {t(locale, 'home.blog_heading')}
          </h2>
          <a
            href={blogHref}
            class="hidden md:inline-flex items-center gap-2 text-[10px] font-mono text-muted hover:text-strong uppercase tracking-widest transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent group"
            aria-label={t(locale, 'home.blog_cta')}
          >
            {t(locale, 'home.blog_cta')}
            <Icon
              name="solar:arrow-right-linear"
              class="motion-safe:group-hover:translate-x-1 transition-transform"
              width={12}
              height={12}
              aria-hidden="true"
            />
          </a>
        </div>

        <!-- Real blog post cards from collection -->
        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px border border-line bg-line sys-reveal"
          role="list"
          aria-label={t(locale, 'home.blog_heading')}
        >
          {latestPosts.map((post) => (
            <div role="listitem">
              <BlogCard
                slug={post.id}
                title={post.data.title}
                excerpt={post.data.excerpt}
                category={post.data.category}
                publishedAt={post.data.publishedAt}
                locale={locale}
              />
            </div>
          ))}
        </div>

        <!-- Mobile "ver todos" -->
        <div class="mt-6 md:hidden">
          <a
            href={blogHref}
            class="inline-flex items-center gap-2 text-[10px] font-mono text-muted hover:text-strong uppercase tracking-widest transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent group"
          >
            {t(locale, 'home.blog_cta')}
            <Icon
              name="solar:arrow-right-linear"
              class="motion-safe:group-hover:translate-x-1 transition-transform"
              width={12}
              height={12}
              aria-hidden="true"
            />
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ── Contato ── -->
  <ContactForm variant="contato" locale={locale} />

  <!-- ── Emergência 24h ── -->
  <Emergency24hCTA locale={locale} />
</BaseLayout>

<!-- Reveal island: drives .sys-reveal → .sys-active via IntersectionObserver -->
<script>
  import '@/scripts/reveal';
</script>

<!-- Hero island: spotlight + parallax (guards: hover:hover AND no prefers-reduced-motion) -->
<script>
  import '@/scripts/hero';
</script>

<!-- Services grid flashlight (guard: hover:hover) -->
<script>
  import '@/scripts/spotlight';
</script>
