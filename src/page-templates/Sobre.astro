---
/**
 * Sobre page template — locale-aware
 *
 * Content source: https://robotersys.com/sobre-nos/ (fetched 2026-06-12)
 *
 * Sections:
 *  1. PageHero "Sobre Nós" with breadcrumbs
 *  2. ProseSection — História (origem em intercâmbio técnico Berlim; KUKA desde 2006)
 *  3. Missão / Visão / Valores via FeatureCard × 3
 *  4. StatsBand "Nosso trabalho em números" (placeholder values)
 *  5. GPTW recognition block
 *  6. Clients strip — ClientsCarousel (same marquee as home)
 *  7. ContactForm variant="contato"
 */
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import ProseSection from '@/components/ProseSection.astro';
import SectionLabel from '@/components/SectionLabel.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import StatsBand from '@/components/StatsBand.astro';
import ClientsCarousel from '@/components/ClientsCarousel.astro';
import ContactForm from '@/components/ContactForm.astro';
import { t } from '@/i18n';
import { brandHtml } from '@/lib/brand';
import type { Locale } from '@/i18n/types';
import { localizedPath } from '@/i18n/routes';

// Real facility and team photos from current site (robotersys.com)
import sobreFacilityImg from '@/assets/robotersys/sobre-facility.webp';
import sobreTeamImg from '@/assets/robotersys/sobre-team.webp';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const crumbs = [
  { label: t(locale, 'sobre.breadcrumb_home'), href: localizedPath('home', locale) },
  { label: t(locale, 'sobre.breadcrumb_page'), href: localizedPath('sobre', locale) },
];

const values = [
  {
    fig: 'VAL. 01',
    icon: 'solar:lightning-linear',
    title: t(locale, 'sobre.value1_title'),
    desc: t(locale, 'sobre.value1_desc'),
    accent: true,
  },
  {
    fig: 'VAL. 02',
    icon: 'solar:medal-ribbon-linear',
    title: t(locale, 'sobre.value2_title'),
    desc: t(locale, 'sobre.value2_desc'),
  },
  {
    fig: 'VAL. 03',
    icon: 'solar:shield-check-linear',
    title: t(locale, 'sobre.value3_title'),
    desc: t(locale, 'sobre.value3_desc'),
  },
];

// PLACEHOLDER NOTE: stat values below are placeholders — confirm with client before go-live.
const stats = [
  { label: t(locale, 'stats.clients_label'),       value: t(locale, 'stats.clients_value') },
  { label: t(locale, 'stats.robots_label'),         value: t(locale, 'stats.robots_value') },
  { label: t(locale, 'stats.interventions_label'),  value: t(locale, 'stats.interventions_value') },
  { label: t(locale, 'stats.support_calls_label'),  value: t(locale, 'stats.support_calls_value') },
  { label: t(locale, 'stats.lines_label'),          value: t(locale, 'stats.lines_value') },
];
---

<BaseLayout
  title={t(locale, 'sobre.page_title')}
  description={t(locale, 'sobre.meta_description')}
  locale={locale}
  pageKey="sobre"
>

  <!-- 1. Hero -->
  <PageHero
    kicker={t(locale, 'sobre.hero_kicker')}
    title={t(locale, 'sobre.hero_title')}
    crumbs={crumbs}
    bgImage={sobreFacilityImg}
  />

  <!-- 2. História -->
  <ProseSection
    kicker={t(locale, 'sobre.historia_label')}
    title={t(locale, 'sobre.historia_title')}
  >
    <p>{t(locale, 'sobre.historia_p1')}</p>
    <p>{t(locale, 'sobre.historia_p2')}</p>
    <p>{t(locale, 'sobre.historia_p3')}</p>
  </ProseSection>

  <!-- 2b. Facility photo — follows História, illustrates the company's space -->
  <div class="border-b border-line overflow-hidden" aria-hidden="true">
    <Image
      src={sobreFacilityImg}
      alt="Instalações da RoboterSys — centro de serviços robóticos KUKA"
      width={1280}
      height={720}
      class="w-full h-64 md:h-96 object-cover object-center"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- 3. Missão / Visão / Valores -->
  <section
    class="py-16 border-b border-line bg-bg"
    aria-labelledby="mvv-heading"
  >
    <div class="container mx-auto px-6 lg:px-12">
      <SectionLabel text={t(locale, 'sobre.mvv_label')} />

      <!-- Missão + Visão (2-col) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 sys-reveal">

        <!-- Missão -->
        <div class="border border-line border-l-2 border-l-accent bg-elevated/20 p-6">
          <p class="text-[10px] font-mono text-accent uppercase tracking-widest mb-3">
            // {t(locale, 'sobre.mission_title')}
          </p>
          <p class="text-fg text-sm leading-relaxed">
            {t(locale, 'sobre.mission_text')}
          </p>
        </div>

        <!-- Visão -->
        <div class="border border-line bg-elevated/20 p-6">
          <p class="text-[10px] font-mono text-muted uppercase tracking-widest mb-3">
            // {t(locale, 'sobre.vision_title')}
          </p>
          <p class="text-fg text-sm leading-relaxed">
            {t(locale, 'sobre.vision_text')}
          </p>
        </div>
      </div>

      <!-- Valores -->
      <h2
        id="mvv-heading"
        class="text-2xl md:text-3xl font-medium text-strong uppercase tracking-tight leading-tight mb-10 sys-reveal sys-rise"
      >
        {t(locale, 'sobre.values_title')}
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sys-reveal">
        {values.map((v) => (
          <FeatureCard
            icon={v.icon}
            title={v.title}
            desc={v.desc}
            fig={v.fig}
            accent={v.accent}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 3b. Team/facility photo — between valores and stats, shows the team at work -->
  <div class="border-b border-line overflow-hidden" aria-hidden="true">
    <Image
      src={sobreTeamImg}
      alt="Equipe técnica da RoboterSys — especialistas em robótica KUKA"
      width={1280}
      height={720}
      class="w-full h-64 md:h-80 object-cover object-center"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- 4. Stats Band -->
  <!-- PLACEHOLDER NOTE: stat values are placeholders — confirm with client before go-live. -->
  <StatsBand stats={stats} />

  <!-- 5. GPTW Recognition -->
  <section
    class="py-16 border-b border-line bg-bg"
    aria-labelledby="gptw-heading"
  >
    <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
      <SectionLabel text={t(locale, 'sobre.gptw_label')} />

      <div class="flex flex-col md:flex-row items-start md:items-center gap-8">

        <!-- GPTW seal — real image from current site (robotersys.com) — Phase 2.5 -->
        <img
          src="/robotersys/img/GPTW-Selos.webp"
          alt="Selo Great Place to Work — RoboterSys certificada GPTW"
          width="120"
          height="120"
          loading="lazy"
          decoding="async"
          class="flex-shrink-0 w-24 h-auto object-contain"
        />

        <div class="flex-1">
          <h2
            id="gptw-heading"
            class="text-2xl md:text-3xl font-medium text-strong uppercase tracking-tight leading-tight mb-4 sys-reveal sys-rise"
          >
            {t(locale, 'sobre.gptw_title')}
          </h2>
          <p class="text-fg text-sm leading-relaxed max-w-2xl">
            {t(locale, 'sobre.gptw_text')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Clients strip -->
  <section
    class="py-16 border-b border-line bg-bg"
    aria-labelledby="sobre-clients-heading"
  >
    <div class="container mx-auto px-6 lg:px-12">
      <SectionLabel text={t(locale, 'sobre.clients_label')} />
      <h2
        id="sobre-clients-heading"
        class="text-2xl md:text-3xl font-medium text-strong uppercase tracking-tight leading-tight mb-10 sys-reveal sys-rise"
        set:html={brandHtml(t(locale, 'sobre.clients_heading'))}
      ></h2>
      <p class="text-muted text-xs mb-10 sys-reveal">
        {t(locale, 'sobre.clients_body')}
      </p>
    </div>

    <!-- Full-bleed marquee: edge-to-edge white band (same as home) -->
    <ClientsCarousel locale={locale} />
  </section>

  <!-- 7. Contact Form -->
  <ContactForm variant="contato" locale={locale} />

</BaseLayout>

<!-- Reveal island -->
<script>
  import '@/scripts/reveal';
</script>
