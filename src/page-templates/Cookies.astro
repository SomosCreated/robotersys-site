---
/**
 * Cookies page template — locale-aware shell.
 *
 * Hero + meta vêm do i18n; o CORPO da política é um componente por idioma
 * (src/page-templates/legal/cookies.<locale>.astro).
 *
 * MINUTA — revisão jurídica recomendada. ÚNICO placeholder: o CNPJ.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import { t } from '@/i18n';
import type { Locale } from '@/i18n/types';
import { localizedPath } from '@/i18n/routes';

import CookiesPt from '@/page-templates/legal/cookies.pt.astro';
import CookiesEn from '@/page-templates/legal/cookies.en.astro';
import CookiesEs from '@/page-templates/legal/cookies.es.astro';
import CookiesDe from '@/page-templates/legal/cookies.de.astro';

interface Props { locale: Locale; }
const { locale } = Astro.props;

const bodies: Record<Locale, typeof CookiesPt> = {
  pt: CookiesPt,
  en: CookiesEn,
  es: CookiesEs,
  de: CookiesDe,
};
const Body = bodies[locale] ?? CookiesPt;

const crumbs = [
  { label: t(locale, 'legal.cookies_breadcrumb_home'), href: localizedPath('home', locale) },
  { label: t(locale, 'legal.cookies_breadcrumb_page'), href: localizedPath('cookies', locale) },
];
---

<BaseLayout
  title={t(locale, 'legal.cookies_page_title')}
  description={t(locale, 'legal.cookies_meta_description')}
  locale={locale}
  pageKey="cookies"
>
  <PageHero
    kicker={t(locale, 'legal.cookies_hero_kicker')}
    title={t(locale, 'legal.cookies_hero_title')}
    crumbs={crumbs}
  />

  <Body locale={locale} />
</BaseLayout>

<script>
  import '@/scripts/reveal';
</script>
