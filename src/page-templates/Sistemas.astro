---
/**
 * Sistemas page template — locale-aware
 *
 * Content source: https://robotersys.com/sistemas-roboticos/ (fetched 2026-06-12)
 *
 * Sections:
 *  1. PageHero "Sistemas Robóticos"
 *  2. Positioning / intro block
 *  3. Applications via FeatureCard × 4
 *  4. CellGallery — 4 cells
 *  5. Clients strip — ClientsCarousel (same marquee as home)
 *  6. ContactForm variant="contato"
 */
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import SectionLabel from '@/components/SectionLabel.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import CellGallery from '@/components/CellGallery.astro';
import ComparisonTable from '@/components/ComparisonTable.astro';
import ClientsCarousel from '@/components/ClientsCarousel.astro';
import ContactForm from '@/components/ContactForm.astro';
import { t } from '@/i18n';
import { brandHtml } from '@/lib/brand';
import type { Locale } from '@/i18n/types';
import { localizedPath } from '@/i18n/routes';

// Page hero — IMG_5696 (engineer at laptop); swapped with Serviços per client request
import sistemasHeroImg from '@/assets/robotersys/sistemas-hero.webp';
// Section band (2b): robot-cell application photo (IMG_5666)
import sistemasRobotImg from '@/assets/robotersys/sistemas-robot-app.webp';

// Real cell photos from the current site (robotersys.com) — harvested in Phase 2.5
import cell01Img from '@/assets/robotersys/cell-01-paletizacao.webp';
import cell02Img from '@/assets/robotersys/cell-02-handling.webp';
import cell03Img from '@/assets/robotersys/cell-03-paletizacao2.webp';
import cell04Img from '@/assets/robotersys/cell-04-rebarbacao.jpg';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const crumbs = [
  { label: t(locale, 'sistemas.breadcrumb_home'), href: localizedPath('home', locale) },
  { label: t(locale, 'sistemas.breadcrumb_page'), href: localizedPath('sistemas', locale) },
];

const applications = [
  {
    icon: 'solar:layers-minimalistic-linear',
    title: t(locale, 'sistemas.app1_title'),
    desc: t(locale, 'sistemas.app1_desc'),
    fig: 'APL. 01',
    accent: true,
  },
  {
    icon: 'solar:transfer-horizontal-linear',
    title: t(locale, 'sistemas.app2_title'),
    desc: t(locale, 'sistemas.app2_desc'),
    fig: 'APL. 02',
  },
  {
    icon: 'solar:settings-linear',
    title: t(locale, 'sistemas.app3_title'),
    desc: t(locale, 'sistemas.app3_desc'),
    fig: 'APL. 03',
  },
  {
    icon: 'solar:refresh-circle-linear',
    title: t(locale, 'sistemas.app4_title'),
    desc: t(locale, 'sistemas.app4_desc'),
    fig: 'APL. 04',
  },
];

const cells = [
  {
    fig: 'CEL. 01',
    title: t(locale, 'sistemas.cell1_title'),
    desc: t(locale, 'sistemas.cell1_desc'),
    href: localizedPath('celulaPaletizacao1', locale),
    ctaLabel: t(locale, 'sistemas.gallery_saiba_mais'),
    imgSrc: cell01Img,
    imgAlt: 'Célula robotizada de paletização KUKA — RoboterSys',
  },
  {
    fig: 'CEL. 02',
    title: t(locale, 'sistemas.cell2_title'),
    desc: t(locale, 'sistemas.cell2_desc'),
    href: localizedPath('celulaPaletizacao2', locale),
    ctaLabel: t(locale, 'sistemas.gallery_saiba_mais'),
    imgSrc: cell03Img,
    imgAlt: 'Segunda célula robotizada de paletização KUKA — RoboterSys',
  },
  {
    fig: 'CEL. 03',
    title: t(locale, 'sistemas.cell3_title'),
    desc: t(locale, 'sistemas.cell3_desc'),
    href: localizedPath('celulasManipulacao', locale),
    ctaLabel: t(locale, 'sistemas.gallery_saiba_mais'),
    imgSrc: cell02Img,
    imgAlt: 'Célula robotizada de handling KUKA — RoboterSys',
  },
  {
    fig: 'CEL. 04',
    title: t(locale, 'sistemas.cell4_title'),
    desc: t(locale, 'sistemas.cell4_desc'),
    href: localizedPath('pushcorp', locale),
    ctaLabel: t(locale, 'sistemas.gallery_saiba_mais'),
    imgSrc: cell04Img,
    imgAlt: 'Célula robotizada de rebarbação e acabamento KUKA — RoboterSys',
  },
];

// ── Capacidades RoboterSys checklist (shown in the "// Automação Industrial" section) ──
const capabilitiesColumns = [
  { label: t(locale, 'compare.col_rs'), sublabel: t(locale, 'compare.best'), highlight: true },
];
const capabilitiesRows = [
  { feature: t(locale, 'capabilities.c1'), cells: ['yes'] as const },
  { feature: t(locale, 'capabilities.c2'), cells: ['yes'] as const },
  { feature: t(locale, 'capabilities.c3'), cells: ['yes'] as const },
  { feature: t(locale, 'capabilities.c4'), cells: ['yes'] as const },
  { feature: t(locale, 'capabilities.c5'), cells: ['yes'] as const },
  { feature: t(locale, 'capabilities.c6'), cells: ['yes'] as const },
];
---

<BaseLayout
  title={t(locale, 'sistemas.page_title')}
  description={t(locale, 'sistemas.meta_description')}
  locale={locale}
  pageKey="sistemas"
>

  <!-- 1. Hero -->
  <PageHero
    kicker={t(locale, 'sistemas.hero_kicker')}
    title={t(locale, 'sistemas.hero_title')}
    crumbs={crumbs}
    bgImage={sistemasHeroImg}
  />

  <!-- 2. Positioning block "// Automação Industrial" — text + Capacidades RoboterSys table (2nd column) -->
  <section
    class="py-16 border-b border-line bg-bg"
    aria-labelledby="sistemas-pos-heading"
  >
    <div class="container mx-auto px-6 lg:px-12 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <!-- Col 1: positioning text -->
        <div>
          <SectionLabel text={t(locale, 'sistemas.pos_label')} />
          <h2
            id="sistemas-pos-heading"
            class="text-2xl md:text-4xl font-medium text-strong uppercase tracking-tight leading-tight mb-6 sys-reveal sys-rise"
          >
            {t(locale, 'sistemas.pos_heading')}
          </h2>
          <p class="text-muted text-sm leading-relaxed">
            {t(locale, 'sistemas.pos_body')}
          </p>
        </div>

        <!-- Col 2: Capacidades RoboterSys checklist (compact) -->
        <div class="sys-reveal">
          <div class="text-[10px] font-mono text-accent uppercase tracking-widest flex items-center gap-2 mb-3">
            <span class="w-1.5 h-1.5 bg-accent animate-pulse" aria-hidden="true"></span>
            // {t(locale, 'capabilities.label')}
          </div>
          <h3
            class="text-base md:text-lg font-medium text-strong uppercase tracking-tight leading-tight mb-5"
            set:html={brandHtml(t(locale, 'capabilities.heading'))}
          ></h3>
          <ComparisonTable
            caption={t(locale, 'capabilities.heading')}
            columns={capabilitiesColumns}
            rows={capabilitiesRows}
            yesLabel={t(locale, 'compare.yes')}
            noLabel={t(locale, 'compare.no')}
            compact
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 2b. Section image — robot application photo from current site -->
  <div class="border-b border-line overflow-hidden" aria-hidden="true">
    <Image
      src={sistemasRobotImg}
      alt="Sistema robótico KUKA em operação industrial — RoboterSys"
      width={1280}
      height={720}
      class="w-full h-64 md:h-96 object-cover object-center"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- 3. Applications -->
  <section
    class="py-16 border-b border-line bg-bg"
    aria-labelledby="sistemas-apps-heading"
  >
    <div class="container mx-auto px-6 lg:px-12">
      <SectionLabel text={t(locale, 'sistemas.apps_label')} />
      <h2
        id="sistemas-apps-heading"
        class="text-2xl md:text-3xl font-medium text-strong uppercase tracking-tight leading-tight mb-10 sys-reveal sys-rise"
      >
        {t(locale, 'sistemas.apps_heading')}
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sys-reveal">
        {applications.map((app) => (
          <FeatureCard
            icon={app.icon}
            title={app.title}
            desc={app.desc}
            fig={app.fig}
            accent={app.accent}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Cell Gallery -->
  <section
    class="py-16 border-b border-line bg-bg"
    aria-labelledby="gallery-heading"
  >
    <div class="container mx-auto px-6 lg:px-12">
      <SectionLabel text={t(locale, 'sistemas.gallery_label')} />
      <h2
        id="gallery-heading"
        class="text-2xl md:text-3xl font-medium text-strong uppercase tracking-tight leading-tight mb-10 sys-reveal sys-rise"
      >
        {t(locale, 'sistemas.gallery_heading')}
      </h2>

      <div class="sys-reveal">
        <CellGallery cells={cells} ctaLabel={t(locale, 'sistemas.gallery_saiba_mais')} />
      </div>
    </div>
  </section>

  <!-- 5. Clients strip -->
  <section
    class="pt-16 border-b border-line bg-bg"
    aria-labelledby="clients-heading"
  >
    <div class="container mx-auto px-6 lg:px-12">
      <SectionLabel text={t(locale, 'sistemas.clients_label')} />
      <h2
        id="clients-heading"
        class="text-2xl md:text-3xl font-medium text-strong uppercase tracking-tight leading-tight mb-10 sys-reveal sys-rise"
        set:html={brandHtml(t(locale, 'sistemas.clients_heading'))}
      ></h2>
      <p class="text-muted text-xs mb-10 sys-reveal">
        {t(locale, 'sistemas.clients_body')}
      </p>
    </div>

    <!-- Full-bleed marquee: edge-to-edge white band (same as home) -->
    <ClientsCarousel locale={locale} />
  </section>

  <!-- 6. Contact Form -->
  <ContactForm variant="contato" locale={locale} />

</BaseLayout>

<!-- Reveal island -->
<script>
  import '@/scripts/reveal';
</script>
