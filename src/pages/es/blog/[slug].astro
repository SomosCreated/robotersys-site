---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import SectionLabel from '@/components/SectionLabel.astro';
import BlogCard from '@/components/BlogCard.astro';
import { Icon } from 'astro-icon/components';
import { t } from '@/i18n';
import { localizedPath } from '@/i18n/routes';

export async function getStaticPaths() {
  const posts = await getCollection('blog', (entry) =>
    entry.data.language === 'es' && !entry.data.draft
  );
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const locale = 'es' as const;
const { entry } = Astro.props;
const { Content } = await render(entry);

const allEsPosts = await getCollection('blog', (e) =>
  e.data.language === 'es' && !e.data.draft && e.id !== entry.id
);
const related = allEsPosts
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const dateStr = entry.data.publishedAt.toLocaleDateString('es-ES', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const siteBase = 'https://robotersys.com';
const postUrl = `${siteBase}/es/blog/${entry.id}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.seoDescription ?? entry.data.excerpt,
  datePublished: entry.data.publishedAt.toISOString().slice(0, 10),
  author: { '@type': 'Person', name: entry.data.author },
  publisher: { '@type': 'Organization', name: 'RoboterSys', url: siteBase },
  url: postUrl,
  inLanguage: 'es',
};
---

<BaseLayout
  title={`${entry.data.title} — RoboterSys`}
  description={entry.data.seoDescription ?? entry.data.excerpt}
  locale={locale}
  pageKey="blog"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <PageHero
    kicker={entry.data.category}
    title={entry.data.title}
    crumbs={[
      { label: t(locale, 'sobre.breadcrumb_home'), href: localizedPath('home', locale) },
      { label: t(locale, 'blog.title'), href: localizedPath('blog', locale) },
      { label: entry.data.title, href: `/es/blog/${entry.id}/` },
    ]}
  />

  <article class="py-16 px-6 md:px-12 bg-bg border-b border-line">
    <div class="max-w-4xl mx-auto">
      <div class="flex flex-wrap items-center gap-4 mb-8 pb-6 border-b border-line">
        <span class="text-[8px] font-mono text-muted uppercase tracking-widest border border-line px-2 py-0.5">
          {entry.data.category}
        </span>
        <time
          datetime={entry.data.publishedAt.toISOString().slice(0, 10)}
          class="text-[10px] font-mono text-muted uppercase tracking-widest"
        >
          {dateStr}
        </time>
        <span class="text-[10px] font-mono text-muted uppercase tracking-widest">
          {entry.data.author}
        </span>
      </div>

      {entry.data.coverImage && (
        <div class="mb-10 overflow-hidden border border-line">
          <Image
            src={entry.data.coverImage}
            alt={entry.data.title}
            width={1200}
            height={675}
            class="w-full h-auto object-cover"
            loading="eager"
          />
        </div>
      )}

      <div class="prose-blog">
        <Content />
      </div>

      <div class="mt-12 pt-8 border-t border-line">
        <a
          href={localizedPath('blog', locale)}
          class="inline-flex items-center gap-2 text-[10px] font-mono text-muted hover:text-strong uppercase tracking-widest transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-accent group"
        >
          <Icon name="solar:arrow-left-linear" class="motion-safe:group-hover:-translate-x-1 transition-transform" width={12} height={12} aria-hidden="true" />
          {t(locale, 'blog.back')}
        </a>
      </div>
    </div>
  </article>

  {related.length > 0 && (
    <section class="py-16 px-6 md:px-12 bg-surface border-b border-line" aria-labelledby="related-heading">
      <div class="max-w-7xl mx-auto">
        <SectionLabel text={t(locale, 'blog.latest_heading')} />
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px border border-line bg-line" role="list">
          {related.map((post) => (
            <div role="listitem">
              <BlogCard slug={post.id} title={post.data.title} excerpt={post.data.excerpt} category={post.data.category} publishedAt={post.data.publishedAt} locale={locale} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .prose-blog { font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.875rem; line-height: 1.75; color: rgb(var(--color-fg)); }
  .prose-blog p { margin-bottom: 1.25rem; max-width: 65ch; }
  .prose-blog h2 { font-size: 1rem; font-weight: 500; color: rgb(var(--color-strong)); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 2.5rem; margin-bottom: 0.75rem; }
  .prose-blog h3 { font-size: 0.875rem; font-weight: 500; color: rgb(var(--color-strong)); text-transform: uppercase; letter-spacing: 0.04em; margin-top: 2rem; margin-bottom: 0.5rem; }
  .prose-blog strong { color: rgb(var(--color-strong)); font-weight: 500; }
  .prose-blog em { color: rgb(var(--color-accent)); font-style: normal; }
  .prose-blog a { color: rgb(var(--color-accent)); text-decoration: underline; text-underline-offset: 3px; }
  .prose-blog ul { list-style: none; padding: 0; margin-bottom: 1.25rem; }
  .prose-blog ul li { display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 0.5rem; }
  .prose-blog ul li::before { content: '—'; color: rgb(var(--color-accent)); flex-shrink: 0; }
  .prose-blog ol { counter-reset: list; padding: 0; margin-bottom: 1.25rem; }
  .prose-blog ol li { counter-increment: list; display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 0.5rem; }
  .prose-blog ol li::before { content: counter(list) '.'; color: rgb(var(--color-accent)); flex-shrink: 0; font-weight: 500; min-width: 1.5rem; }
  .prose-blog table { width: 100%; border-collapse: collapse; margin-bottom: 1.25rem; font-size: 0.8125rem; }
  .prose-blog th, .prose-blog td { border: 1px solid rgb(var(--color-line)); padding: 0.5rem 0.75rem; text-align: left; }
  .prose-blog th { color: rgb(var(--color-strong)); background: rgb(var(--color-surface)); font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; font-size: 0.75rem; }
  .prose-blog code { font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.8125rem; background: rgb(var(--color-surface)); border: 1px solid rgb(var(--color-line)); padding: 0.1rem 0.35rem; color: rgb(var(--color-accent)); }
  .prose-blog blockquote { border-left: 3px solid rgb(var(--color-accent)); padding-left: 1rem; margin-left: 0; color: rgb(var(--color-muted)); }
</style>
