# Resend (e-mail transacional)
RESEND_API_KEY=
RESEND_FROM="RoboterSys <site@robotersys.com.br>"
CONTACT_TO_COMMERCIAL=comercial@robotersys.com.br
CONTACT_TO_RH=rh@robotersys.com.br
# Ploomes (CRM) — confirmar mapeamento de funil/estágio/campos com o cliente
PLOOMES_API_KEY=
PLOOMES_API_BASE=https://public-api2.ploomes.com

# Medição (Consent Mode v2 — preencher para ativar GTM/GA4/Ads; vazio = nada carrega)
# GA4 e Google Ads são configurados DENTRO do contêiner GTM; os IDs abaixo ficam documentados
# aqui para referência (e para um eventual fallback gtag-direto no futuro).
PUBLIC_GTM_ID=
PUBLIC_GA4_ID=
PUBLIC_ADS_ID=
PUBLIC_ADS_CONVERSION_LABEL=

# Keystatic (CMS do blog) — necessário SOMENTE em produção (storage: 'github') para que
# o cliente edite posts pelo painel /keystatic. Em dev local o storage é 'local' (disco)
# e nenhuma destas variáveis é exigida. Configurar no Vercel (Production + Preview).
# Passo a passo: docs/reference/deploy-runbook.md §2 e keystatic.config.ts.
#   1. Instalar o Keystatic GitHub App no repo: https://keystatic.com/docs/github-app
#   2. Copiar Client ID / Client Secret do GitHub App; gerar um KEYSTATIC_SECRET aleatório.
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=                          # segredo aleatório de 32+ caracteres (ex.: `openssl rand -hex 32`)
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=          # slug do GitHub App instalado (parte pública)
